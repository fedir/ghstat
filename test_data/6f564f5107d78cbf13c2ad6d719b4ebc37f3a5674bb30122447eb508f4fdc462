 don't defer + transfer\nthem upon merge, the branch would still be marked clean but the effect\nbehind it is dirty but no longer reachable. It's not reachable via mark\neither because that one only concerns itself with block/async effects,\nand the branch gating the effect is not guaranteed to be touched by\nthat.\n\nFixes #18249\n\nLittle sad side-effect: Since we cannot reliably know _before_ traversal\nif we have no blocking pending work left (the traversal could mark an if\nblock falsy which contains the last blocker), we gotta undo a\nperformance optimization.","tree":{"sha":"c6114f9f0da84ccac76744e805ceb18389439290","url":"https://api.github.com/repos/sveltejs/svelte/git/trees/c6114f9f0da84ccac76744e805ceb18389439290"},"url":"https://api.github.com/repos/sveltejs/svelte/git/commits/65283bc13a54c41ee96940b559c1a027b8770882","comment_count":0,"verification":{"verified":true,"reason":"valid","signature":"-----BEGIN PGP SIGNATURE-----\n\nwsFcBAABCAAQBQJqDixyCRC1aQ7uu5UhlAAAMOIQADhkpLLCoRk+5WRQKLBt1GwH\nkMGJINTEB21cU1pBdshbZ3rgRp+XBfdynVUEusW8DboPt6g9q+QzvpE+3nMVnSy8\ndQZebHXvUFqdnHflOKJaz/tseU62pr+DssSNVYBpg5zuQqU+7OmcIFlXvPoaFZFe\nSMfZOoiYc7QfHi98ORFtJYf/HYUm9qB4t3aMxlZES3ccyXhdYUa9M56oN8fL7lHW\nF0qOnHnIeFc3LoKqZualn92domSHjj8EclwTcM97w/VKpZfsn9s8uVPD5bUbhDAn\nXCqTVKP3XJTpVrznt7+aq3OIvmaHjtYqr0LCPgUxnW8RlaEsxbdW1xKMJIfZnfQn\nZBV8lPBDH4/co6OBkqVn11vqHTxh2z57QxiUQY54fG9Xo80DufX8BzEpHSunORcn\n39QeSdivrcsbS6tkX4UpkbvG/0GUwVeqb/FDHfLa+N33rrij7Ny9dNTLZyuw0Uhd\nUNWUdnLMqaB6+fjlz/hhqOuG3CTER6ZI/XNSMY9R7Ux37xyzyTwoO+b4o0vD3FXH\nXPTM7WGZMlLQwr0ldaKgMPGIEjffIPxjGbIcIlxYXFXO2p/v4B9UCQa8kvO5EOi/\nwLVz3n+nHYb3ffGCy0lyjLQNL82T4BQEyq6vGLa/wZ23V92B/GgM0X9DZPEdSPpW\n2tA45WLyfzg7W9feg4gl\n=ClAp\n-----END PGP SIGNATURE-----\n","payload":"tree c6114f9f0da84ccac76744e805ceb18389439290\nparent b65a3f3fc5e1607966e3e27f7e28fc691e622683\nauthor Simon H <5968653+dummdidumm@users.noreply.github.com> 1779313778 +0200\ncommitter GitHub <noreply@github.com> 1779313778 +0200\n\nfix: transfer effects when merging batches (#18254)\n\nAn effect could be gated behind a branch. If we don't defer + transfer\nthem upon merge, the branch would still be marked clean but the effect\nbehind it is dirty but no longer reachable. It's not reachable via mark\neither because that one only concerns itself with block/async effects,\nand the branch gating the effect is not guaranteed to be touched by\nthat.\n\nFixes #18249\n\nLittle sad side-effect: Since we cannot reliably know _before_ traversal\nif we have no blocking pending work left (the traversal could mark an if\nblock falsy which contains the last blocker), we gotta undo a\nperformance optimization.","verified_at":"2026-05-20T21:49:39Z"}},"url":"https://api.github.com/repos/sveltejs/svelte/commits/65283bc13a54c41ee96940b559c1a027b8770882","html_url":"https://github.com/sveltejs/svelte/commit/65283bc13a54c41ee96940b559c1a027b8770882","comments_url":"https://api.github.com/repos/sveltejs/svelte/commits/65283bc13a54c41ee96940b559c1a027b8770882/comments","author":{"login":"dummdidumm","id":5968653,"node_id":"MDQ6VXNlcjU5Njg2NTM=","avatar_url":"https://avatars.githubusercontent.com/u/5968653?v=4","gravatar_id":"","url":"https://api.github.com/users/dummdidumm","html_url":"https://github.com/dummdidumm","followers_url":"https://api.github.com/users/dummdidumm/followers","following_url":"https://api.github.com/users/dummdidumm/following{/other_user}","gists_url":"https://api.github.com/users/dummdidumm/gists{/gist_id}","starred_url":"https://api.github.com/users/dummdidumm/starred{/owner}{/repo}","subscriptions_url":"https://api.github.com/users/dummdidumm/subscriptions","organizations_url":"https://api.github.com/users/dummdidumm/orgs","repos_url":"https://api.github.com/users/dummdidumm/repos","events_url":"https://api.github.com/users/dummdidumm/events{/privacy}","received_events_url":"https://api.github.com/users/dummdidumm/received_events","type":"User","user_view_type":"public","site_admin":false},"committer":{"log