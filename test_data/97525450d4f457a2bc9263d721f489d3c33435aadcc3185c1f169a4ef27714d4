/users/web-flow/received_events","type":"User","user_view_type":"public","site_admin":false},"parents":[{"sha":"2ca99e1e81dae6d9b8f5f5531d47171c9a8a1660","url":"https://api.github.com/repos/vercel/next.js/commits/2ca99e1e81dae6d9b8f5f5531d47171c9a8a1660","html_url":"https://github.com/vercel/next.js/commit/2ca99e1e81dae6d9b8f5f5531d47171c9a8a1660"}]},{"sha":"2ca99e1e81dae6d9b8f5f5531d47171c9a8a1660","node_id":"C_kwDOBC3CitoAKDJjYTk5ZTFlODFkYWU2ZDliOGY1ZjU1MzFkNDcxNzFjOWE4YTE2NjA","commit":{"author":{"name":"Andrew Clark","email":"git@andrewclark.io","date":"2026-05-20T23:37:48Z"},"committer":{"name":"GitHub","email":"noreply@github.com","date":"2026-05-20T23:37:48Z"},"message":"Add experimental.appShells feature flag (#93997)\n\nPlumbing for upcoming App Shell prefetching support: sets up the config\nfield, the zod entry, and the build-time `process.env.__NEXT_APP_SHELLS`\ndefine. No behavior change in this PR — nothing reads the flag yet.\nSubsequent PRs in this sequence wire the server- and client-side work\nbehind it.\n\nEnabling `experimental.appShells` requires several adjacent flags to\nalso be enabled: `cacheComponents`, `experimental.prefetchInlining`,\n`experimental.varyParams`, `experimental.optimisticRouting`, and\n`experimental.cachedNavigations`. All of these are on track to become\ndefaults soon, so there's no value in supporting App Shells against\narbitrary subsets — the validation enforces that App Shells is tested in\nthe configuration it will ship with. Each requirement drops out as the\ncorresponding flag becomes a default.\n<!-- NEXT_JS_LLM_PR -->","tree":{"sha":"5f1dd804d5649d7ec1e80b5d54e9309f7e1606c6","url":"https://api.github.com/repos/vercel/next.js/git/trees/5f1dd804d5649d7ec1e80b5d54e9309f7e1606c6"},"url":"https://api.github.com/repos/vercel/next.js/git/commits/2ca99e1e81dae6d9b8f5f5531d47171c9a8a1660","comment_count":0,"verification":{"verified":true,"reason":"valid","signature":"-----BEGIN PGP SIGNATURE-----\n\nwsFcBAABCAAQBQJqDkXMCRC1aQ7uu5UhlAAAFwsQAGn5YQD9wYd3hGwD4eMeIKue\nacniPBzSfIcPfghrzDlVIayBbgGap/sDDwFNuB37W8PpVuKd8c2XcqMBFLuUHC5E\n4ohgcsSz1y/zP49X425mykwl7Nu0j75ppdonK+lm7TNi17KiF+H4wKgkOaIy99lX\n1445qf5i6pya3XJpB5Eq3dUa0a+heRDEsakUY9tu5Y+jd12vnBToEOpYejhWchCQ\n/Mo17zQypDdUkzuefXVTApaZ7bZYSZppHKbvpa8x+I37Mxo+O8OGw8aJwUirWoop\ny42WAPPMI4ErQheAE5ytRfeoxMuioN7s78pz8+wmMX/+O5LKkhRwd1nZtPPX/XkK\ngq4VkvXOsW5cF6UoKWV5pQ+62vyHU6h8Jp97BhddJJIOWsx1v7KxzfuMG7DDFpnl\nd4GL8mUiYQturEbXK37SpHxbgb7gqJt2tIeGaL5XsRBiTsS21Qra6oKlNYfG2f+g\nuTeiv0Lv+LDPnEuuPbt1TSBiyC83dbqz2AKlVSKORyn6fs2ax+y9JK6Kuzugp3pi\nTronBGNAlkML0wLT/qLoF5aC69XmucyHE54mzKw1b5c3YRFeiTy3nVEhqNtQSZnZ\nBFKdcQYxffKAIPGBoYX9UGrygC17rO3khJGHffOtt3Sch4hqtSZk7JM7Or8T+oNg\nt3UJ0+AYI7aRVSf/rfU9\n=jSO8\n-----END PGP SIGNATURE-----\n","payload":"tree 5f1dd804d5649d7ec1e80b5d54e9309f7e1606c6\nparent 5b6747ad3fd34ebcc409e3743b705524b420a122\nauthor Andrew Clark <git@andrewclark.io> 1779320268 -0400\ncommitter GitHub <noreply@github.com> 1779320268 -0400\n\nAdd experimental.appShells feature flag (#93997)\n\nPlumbing for upcoming App Shell prefetching support: sets up the config\nfield, the zod entry, and the build-time `process.env.__NEXT_APP_SHELLS`\ndefine. No behavior change in this PR — nothing reads the flag yet.\nSubsequent PRs in this sequence wire the server- and client-side work\nbehind it.\n\nEnabling `experimental.appShells` requires several adjacent flags to\nalso be enabled: `cacheComponents`, `experimental.prefetchInlining`,\n`experimental.varyParams`, `experimental.optimisticRouting`, and\n`experimental.cachedNavigations`. All of these are on track to become\ndefaults soon, so there's no value in supporting App Shells against\narbitrary subsets — the validation enforces that App Shells is tested in\nthe configuration it will ship with. Each requirement drops out as the\ncorresponding flag becomes a default.\n<!-- NEXT_JS_LLM_PR -->","verified_at":"2026-05-20T23:37:48Z"}},"url":"https://api.github.com/repos/vercel/next.js/commits/2ca99e1e