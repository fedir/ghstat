nus\": \"11.1.1\",\n    \"reflect-metadata\": \"0.2.2\",\n    \"rxjs\": \"7.8.2\"\n  },\n  \"devDependencies\": {\n    \"@nestjs/cli\": \"11.0.21\",\n    \"@types/node\": \"22.10.0\",\n    \"typescript\": \"5.7.2\"\n  }\n}\n```\n\n\n### Node.js version\n\n24.13.0\n\n### In which operating systems have you tested?\n\n- [ ] macOS\n- [ ] Windows\n- [x] Linux\n\n### Other\n\n_No response_","reactions":{"url":"https://api.github.com/repos/nestjs/nest/issues/16998/reactions","total_count":0,"+1":0,"-1":0,"laugh":0,"hooray":0,"confused":0,"heart":0,"rocket":0,"eyes":0},"timeline_url":"https://api.github.com/repos/nestjs/nest/issues/16998/timeline","performed_via_github_app":null,"state_reason":"completed","pinned_comment":null,"score":1.0},{"url":"https://api.github.com/repos/rodrigowbazevedo/zod-nest/issues/42","repository_url":"https://api.github.com/repos/rodrigowbazevedo/zod-nest","labels_url":"https://api.github.com/repos/rodrigowbazevedo/zod-nest/issues/42/labels{/name}","comments_url":"https://api.github.com/repos/rodrigowbazevedo/zod-nest/issues/42/comments","events_url":"https://api.github.com/repos/rodrigowbazevedo/zod-nest/issues/42/events","html_url":"https://github.com/rodrigowbazevedo/zod-nest/issues/42","id":4465638464,"node_id":"I_kwDOSfitT88AAAABCiw8QA","number":42,"title":"compat-matrix failure: zod-latest","user":{"login":"github-actions[bot]","id":41898282,"node_id":"MDM6Qm90NDE4OTgyODI=","avatar_url":"https://avatars.githubusercontent.com/in/15368?v=4","gravatar_id":"","url":"https://api.github.com/users/github-actions%5Bbot%5D","html_url":"https://github.com/apps/github-actions","followers_url":"https://api.github.com/users/github-actions%5Bbot%5D/followers","following_url":"https://api.github.com/users/github-actions%5Bbot%5D/following{/other_user}","gists_url":"https://api.github.com/users/github-actions%5Bbot%5D/gists{/gist_id}","starred_url":"https://api.github.com/users/github-actions%5Bbot%5D/starred{/owner}{/repo}","subscriptions_url":"https://