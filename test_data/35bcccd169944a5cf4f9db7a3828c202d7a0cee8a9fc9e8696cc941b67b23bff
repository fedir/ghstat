-05-10T17:16:47Z","updated_at":"2026-05-10T18:07:59Z","closed_at":"2026-05-10T18:07:57Z","assignee":null,"author_association":"NONE","issue_field_values":[],"type":null,"active_lock_reason":null,"sub_issues_summary":{"total":0,"completed":0,"percent_completed":0},"issue_dependencies_summary":{"blocked_by":0,"total_blocked_by":0,"blocking":0,"total_blocking":0},"body":"### Is there an existing issue for this?\n\n- [x] I have searched the existing issues\n\n### Current behavior\n\n### Description\nInstalling `@nestjs/cli@11.0.21` fails with pnpm due to a trust downgrade error for `chokidar@4.0.3`.\n\n### Error\nERR_PNPM_TRUST_DOWNGRADE High-risk trust downgrade for \"chokidar@4.0.3\" (possible package takeover)\n\nThis error happened while installing the dependencies of @nestjs/cli@11.0.21\n\nTrust checks are based solely on publish date, not semver. A package cannot be installed if any earlier-published version had stronger trust evidence. Earlier versions had provenance attestation, but this version has no trust evidence.\n\n### Minimum reproduction code\n\nhttps://github.com/nestjs/nest-cli\n\n### Steps to reproduce\n\n\n### Steps to Reproduce\n1. Create a new NestJS project with pnpm\n2. Run `pnpm install`\n3. Error occurs during dependency resolution\n\n### Expected Behavior\nPackage should install successfully without trust warnings.\n\n### Root Cause\n`chokidar@4.0.3` lacks provenance attestation while earlier versions had it. pnpm's security checks reject this \"trust downgrade\".\n\n### Environment\n- pnpm version: [your version]\n- Node.js version: 24+\n- OS: Windows/macOS/Linux\n\n### Suggested Fix\n- Update `chokidar` to a version with provenance attestation, OR\n- Downgrade to a version of `@nestjs/cli` that uses `chokidar` with provenance\n\n### Expected behavior\n\nUpgrade the chokidar dependency to version 5.0 or above\n\n### Package version\n\n11.0.21\n\n### NestJS version\n\n11.1.19\n\n### Node.js version\n\n24.15.0\n\n### In which operating systems have you tested?\n\n- [ ] macOS\n- [x] Windows\n- [ ] Linux\n\n### Other\n\n_No response_","reactions":{"url":"https://api.github.com/repos/nestjs/nest-cli/issues/3439/reactions","total_count":1,"+1":1,"-1":0,"laugh":0,"hooray":0,"confused":0,"heart":0,"rocket":0,"eyes":0},"timeline_url":"https://api.github.com/repos/nestjs/nest-cli/issues/3439/timeline","performed_via_github_app":null,"state_reason":"completed","pinned_comment":null,"score":1.0},{"url":"https://api.github.com/repos/rodrigowbazevedo/zod-nest/issues/32","repository_url":"https://api.github.com/repos/rodrigowbazevedo/zod-nest","labels_url":"https://api.github.com/repos/rodrigowbazevedo/zod-nest/issues/32/labels{/name}","comments_url":"https://api.github.com/repos/rodrigowbazevedo/zod-nest/issues/32/comments","events_url":"https://api.github.com/repos/rodrigowbazevedo/zod-nest/issues/32/events","html_url":"https://github.com/rodrigowbazevedo/zod-nest/issues/32","id":4465081215,"node_id":"I_kwDOSfitT88AAAABCiO7fw","number":32,"title":"Plan: Phase 4b — Public consumer-facing skills","user":{"login":"rodrigowbazevedo","id":6214250,"node_id":"MDQ6VXNlcjYyMTQyNTA=","avatar_url":"https://avatars.githubusercontent.com/u/6214250?v=4","gravatar_id":"","url":"https://api.github.com/users/rodrigowbazevedo","html_url":"https://github.com/rodrigowbazevedo","followers_url":"https://api.github.com/users/rodrigowbazevedo/followers","following_url":"https://api.github.com/users/rodrigowbazevedo/following{/other_user}","gists_url":"https://api.github.com/users/rodrigowbazevedo/gists{/gist_id}","starred_url":"https://api.github.com/users/rodrigowbazevedo/starred{/owner}{/repo}","subscriptions_url":"https://api.github.com/users/rodrigowbazevedo/subscriptions","organizations_url":"https://api.github.com/users/rodrigowbazevedo/orgs","repos_url":"https://api.github.com/users/rodrigowbazevedo/repos","events_url":"https://api.github.com/users/rodrigowbazevedo/events{/privacy}","received_events_url":"https://api.github.com/users/rodrigowbazevedo/received_events","type":"User","user_view_type":"public","site_admin":false},"labels":[{"id":10972468768,"node_id":"LA_kwDOSfitT88AAAACjgKWIA","url":"https://api.github.com/repos/rodrigowbazevedo/zod-nest/labels/plan","name":"plan","color":"0075ca","default":false,"description":"Saved planning session"}],"state":"closed","locked":false,"assignees":[],"milestone":null,"comments":0,"created_at":"2026-05-17T22:06:58Z","updated_at":"2026-05-17T23:49:05Z","closed_at":"2026-05-17T23:49:05Z","assignee":null,"author_association":"OWNER","active_lock_reason":null,"sub_issues_summary":{"total":0,"completed":0,"percent_completed":0},"issue_dependencies_summary":{"blocked_by":0,"total_blocked_by":0,"blocking":0,"total_blocking":0},"body":"# Phase 4b — Public consumer-facing skills\n\n## Context\n\nPhase 3 shipped consumer prose (README + docs + MIGRATION.md). Phase 4 shipped 6 internal contributor skills under `.claude/skills/` + `CLAUDE.md` + PreToolUse hook (PR #27, v0.8.0/v0.8.1 live on npm). Phase 4b fills the gap between them: AI-agent skills shipped *to library users* via `npx skills add rodrigowbazevedo/zod-nest`. Repo already public; layout clear (no root `skills/` dir, no gitignore conflict). Pre-Phase-5 (CI lint of `SKILL.md` frontmatter + drift CI job land in Phase 5).\n\nTwo skills:\n1. **`zod-nest-migrate`** — explicit-only, plan-then-apply, mirrors MIGRATION.md.\n2. **`zod-nest`** — best-practices for schema + handler ergonomics (no opinionated knobs).\n\n## Re-evaluation deltas vs `.plan/phase-4b-public-skills.md`\n\n- **MIGRATION.md is 8 steps, not 7.** Plan file says \"7-step skeleton\"; reality is bump-zod / swap-package / swap-imports / swagger-setup / handlers / forRoot / reflections-and-.Output / verify. `zod-nest-migrate` SKILL.md must mirror the 8 actual steps.\n- **`extend()` is public + already `@experimental`.** `docs/composition.md:1–3` carries: *\"@experimental — output shape may change as edge cases surface. Pin a minor version if you build production tooling on top of this surface.\"* The `zod-nest` skill quotes this verbatim on composition suggestions.\n- **README insertion point exact:** after line 462, before `## Contributing` (l.464). No `skills`/`npx skills`/`.claude/` references in README to collide with.\n- **Phase 4 skill shape to mirror:** YAML frontmatter `{name, description}` only. `references/` linked via relative markdown. Numbered-step workflow. `Out of scope` + `Notes` footer. `sync-docs` adds `## Output contract` early — keep that for `zod-nest` (diagnostic skill); skip for `zod-nest-migrate` (procedural, like `schema-fixture`).\n- **External-consumer constraint (NEW).** `npx skills add` only copies `SKILL.md` + `references/` into the consumer's project — **MIGRATION.md, README.md, `docs/*` do NOT travel with the skill**. Design implications:\n  1. **Orchestrator shape, not self-contained replica.** Skill + references stay concise: per-step prompts gate the work, but the *content* (commands, diffs, full breaking-changes table, precedence chain) lives in the canonical docs and is fetched by the agent via GitHub URLs. Offline-agent fallback is **out of scope** (accepted tradeoff — keeps the skill maintainable and drift-free).\n  2. **Absolute GitHub URLs for cross-repo refs.** Any link inside `skills/<name>/**` pointing outside that skill bundle uses `https://github.com/rodrigowbazevedo/zod-nest/blob/main/<path>` (with `#anchor` where useful). Relative paths reserved for sibling files within the same skill bundle (SKILL.md ↔ references/*.md).\n  3. **No content duplication.** The 8-step skeleton lives in MIGRATION.md (canonical) — `migration-steps.md` is a thin checklist of step *titles* + URL anchors. Same for `transformation-rules.md` (one-line codemod hint per row + URL to MIGRATION.md's breaking-changes table) and `pitfalls.md` (one-liner per gotcha + URL anchor). The `@experimental` composition warning is a single-line quote (it IS one line) + link to `docs/composition.md`.\n\n## Branch posture\n\nCurrently on `chore/explicit-release-pipeline` (merged via PR #28). Origin/main at `b4caced` (`chore(release): 0.8.1`). Steps:\n\n1. `git checkout main && git pull --ff-only origin main`\n2. `git checkout -b phase-4b-public-skills`\n3. Verify clean tree (`CLAUDE_BKP.md` stays untracked — never stage).\n4. `plan-to-github-issue` after `ExitPlanMode` creates issue #N + writes `git config --local branch.phase-4b-public-skills.github-issue <N>`.\n\n## Files to create / modify\n\n**New (root `skills/`):**\n- `skills/zod-nest-migrate/SKILL.md` — frontmatter + 8-step orchestrator. Each step: one-line prompt + URL to the relevant `MIGRATION.md#step-N` anchor + confirmation gate. No content duplication.\n- `skills/zod-nest-migrate/references/migration-steps.md` — thin checklist: 8 step titles, each with a URL to `MIGRATION.md#step-N`. Used by SKILL.md as the loop driver.\n- `skills/zod-nest-migrate/references/transformation-rules.md` — one row per MIGRATION.md breaking-changes table entry: *\"`<old>` → `<new>` (see <url>#row-anchor)\"*. One line per rule + URL.\n- `skills/zod-nest-migrate/references/pitfalls.md` — one-liner per known gotcha (hybrid `class-validator`+`createZodDto`, deep `ZodSerializerDtoOptions`, 500-body shape change) + URL to the relevant FAQ entry / section in MIGRATION.md or `docs/exceptions.md`. **No mention of `nestjs-zod-fork`** — that's a private fork, out of scope for the public skill.\n- `skills/zod-nest/SKILL.md` — frontmatter (with tight description-trigger on `*.controller.ts` / `*.dto.ts` importing `zod-nest`) + `Output contract` + diagnostic workflow. Cross-repo links via absolute GitHub URLs.\n- `skills/zod-nest/references/schema-ergonomics.md` — thin diagnostic catalog: each diagnostic = name + one-sentence detection rule + URL to `docs/dto.md` / `docs/composition.md`. The composition `@experimental` warning is the one-line quote inlined, then URL backlink.\n- `skills/zod-nest/references/handler-ergonomics.md` — thin diagnostic catalog: each diagnostic + URL to `docs/responses.md`. Precedence chain is one bullet line + URL.\n- `docs/skills.md` — user-facing index: install commands, what each does, when to use which.\n\n**Modified:**\n- `README.md` — insert `## AI tooling — \\`npx skills\\`` section between l.462 and l.464 (after \"Migration from `nestjs-zod`\", before \"Contributing\"). Links to `docs/skills.md`. Three install commands (all-skills, migrate-only, best-practices-only).\n- `MIGRATION.md` — top callout under H1 (before TL;DR): *\"Prefer driving this migration with Claude / Cursor? `npx skills add rodrigowbazevedo/zod-nest --skill zod-nest-migrate`\"*.\n\n**Not modified (deferred):**\n- `.claude/skills/sync-docs/SKILL.md` — original plan extended it to drift-check `migration-steps.md` against MIGRATION.md. **Dropped:** with the orchestrator/thin shape there's no meaningful snapshot to drift against (the reference is just titles + URLs). The frontmatter-validation CI job in Phase 5 covers the structural shape; URL liveness is out of scope (no broken-link checker in this phase).\n\n## Skill 1 — `zod-nest-migrate` (orchestrator, like `schema-fixture` in shape)\n\n**Trigger phrases in description:** \"migrate from nestjs-zod\", \"switch to zod-nest\", \"upgrade nestjs-zod\", \"port nestjs-zod to zod-nest\", \"drop class-validator from nestjs-zod project\", \"convert createZodDto to zod-nest\", \"replace cleanupOpenApiDoc with applyZodNest\". **Explicit invocation only** (heavy operation). No auto-trigger.\n\n**Orchestrator workflow** (drives MIGRATION.md from the outside; never re-states its content):\n\n1. **Audit** — detect `nestjs-zod` install/version, zod version, presence of `class-validator`/`class-transformer`, count `@ZodSerializerDto`/`createZodDto`/`ZodValidationPipe`/`ZodDto`/`cleanupOpenApiDoc` callsites. Report status.\n2. **Plan** — list the 8 MIGRATION.md steps with applicability markers from the audit. Each entry shows the URL anchor: `https://github.com/rodrigowbazevedo/zod-nest/blob/main/MIGRATION.md#step-N--<slug>`. Wait for user confirmation.\n3. **Loop steps 1–8** — for each applicable step:\n   - Print: *\"Step N — <title>. Canonical: <URL>. Read the section, propose the edits for this codebase, then ask the user to confirm.\"*\n   - Agent fetches/reads the canonical step content (via WebFetch or equivalent), proposes the per-codebase diff, halts for confirmation.\n   - SKILL.md does NOT inline step content — only the orchestration glue. (Per external-consumer rule: keep skill thin; canonical is the source of truth.)\n4. **Cross-cutting reminders** surfaced at the right step from `pitfalls.md`:\n   - At Step 5: `@HttpCode` rule (URL anchor to MIGRATION.md `#step-5--rewrite-response-handlers`).\n   - At Step 7: discriminator change + `.Output` shape.\n   - At Step 8: 500-body opacity (`errors` field removed) — link to MIGRATION.md `#serialization-exception-body-changes`.\n5. **Verify** — run user's `tsc --noEmit` + `npm test`; surface failures and map them to `pitfalls.md` entries (one-liner each, with URL anchors back into MIGRATION.md FAQ).\n\n## Skill 2 — `zod-nest` (diagnostic, like `sync-docs`)\n\n**Trigger phrases:** \"review my zod-nest code\", \"improve my zod schemas\", \"audit zod-nest usage\", \"extract inline schema\", \"name this schema for OpenAPI\", \"missing @ZodResponse\", \"stack @ZodResponse\", \"leverage zod-nest\", \"best practices zod-nest\".\n\n**Auto-trigger scope (tight, conservative):** description phrases triggers as *\"use when editing a `*.controller.ts` or `*.dto.ts` file that imports from `zod-nest`\"*. Widen later if users miss diagnostics. Slash `/zod-nest` also explicit.\n\n**Mode:** diagnose + propose (never auto-apply). Returns prioritized checklist with file:line anchors.\n\n**Schema ergonomics diagnostics:**\n- Missing `.meta({ id })` on reused schemas (scan for `z.object(...)` consts referenced in ≥2 `createZodDto` callsites).\n- Inline `z.object(...)` inside `createZodDto` — non-trivial (>2 fields) or used in >1 DTO: suggest hoisting + `.meta({ id })`.\n- Anonymous shared shapes (heuristic match: same keys + same types across files) — suggest unifying.\n- Composition opportunity (`.extend()` candidate when two schemas share a field prefix) — quote `@experimental` warning verbatim from `docs/composition.md:1–3`.\n\n**Handler ergonomics diagnostics:**\n- Missing `@ZodResponse` (handler returns `createZodDto` class but no decorator).\n- Single `@ZodResponse` with multi-status intent (multiple `@ApiResponse` calls + only one `@ZodResponse`) — suggest stacking.\n- `@ZodResponse` + redundant `@ApiOkResponse({ type })` referencing the same DTO.\n\n**Explicitly NOT diagnosed (per user direction — don't influence preferences):** `passthroughOnError`, custom exception factories, `validationLogs`/`redactKeys`/logger, `Override` callbacks.\n\n## SKILL.md frontmatter\n\n```yaml\n---\nname: <skill-name>\ndescription: >\n  <one-paragraph summary with trigger phrases inlined>\n---\n```\n\nTwo keys only, matching Phase 4 convention (`schema-fixture`/`sync-docs`).\n\n## PR + commit slicing\n\nBranch: `phase-4b-public-skills`. PR title: `feat(skills): public consumer-facing skills (migrate + best-practices)`.\n\nCommits (4):\n1. `feat(skills): scaffold public skills layout + docs/skills.md` — creates `skills/` dirs, `docs/skills.md`, README \"AI tooling\" section.\n2. `feat(skills): zod-nest-migrate` — SKILL.md + 3 thin references.\n3. `feat(skills): zod-nest (best-practices)` — SKILL.md + 2 thin references.\n4. `docs(migration): callout for npx skills migrate` — MIGRATION.md callout.\n\nConventional-commit prefixes chosen for semantic-release: `feat(skills): …` triggers a minor bump on squash-merge (next release would be `0.9.0`).\n\n## Verification\n\n1. **Static / lib sanity** — `npm run lint && npm run typecheck && npm test && npm run build` all green (no `src/` changes expected; verify nothing broke).\n2. **npx skills end-to-end** — against a throwaway test repo:\n   - `npx skills add rodrigowbazevedo/zod-nest --skill zod-nest-migrate` → installs SKILL.md + 3 references into `.claude/skills/zod-nest-migrate/`.\n   - `npx skills add rodrigowbazevedo/zod-nest --skill zod-nest` → installs SKILL.md + 2 references into `.claude/skills/zod-nest/`.\n   - `npx skills add rodrigowbazevedo/zod-nest -l` (list) shows both.\n3. **Manual smoke `/zod-nest-migrate`** — on a real `nestjs-zod` project under `~/Projects/`, invoke and walk through 8 steps. Each step halts for confirmation.\n4. **Manual smoke `/zod-nest`** — hand-write 2–3 controllers/DTOs with intentional anti-patterns (no `.meta({ id })`, missing `@ZodResponse`, multi-status candidate, redundant `@ApiOkResponse`). Confirm each diagnostic fires; confirm NO diagnostics for `passthroughOnError` / `validationLogs` / `Override`.\n5. **Pre-PR hook clear** — run `/sync-docs` (README + MIGRATION + `docs/skills.md` cohere) + `/api-surface-audit` (no public surface change expected). Both pass before `gh pr create`.\n6. **README + docs/skills.md render cleanly on GitHub**; install commands copy-paste cleanly.\n\n## Out of scope (defer to Phase 5 or later)\n\n- `SKILL.md` frontmatter validation CI job (Phase 5).\n- Broken-link / URL liveness check on the skill bundles (no CI in this phase).\n- Offline-agent fallback — skills assume the agent can fetch GitHub URLs.\n- Multi-agent validation (Cursor / Continue) — Claude Code primary, others best-effort.\n- Auto-apply migrate mode — per-step confirmation only in v0.\n- Consumer scaffolding skills (`/zod-dto`, `/zod-response`) — re-evaluate post-v0.\n- Independent skill versioning — skills ship with the package via semantic-release.\n\n## Skills to use during execution\n\n- `/skill-creator` — author each new public skill; mirror Phase 4 conventions (YAML 2-key frontmatter, `references/`, numbered workflow).\n- `/sync-docs` — verify README + MIGRATION + `docs/skills.md` cohere after Phase 4b commits; also smoke-test the new migration-steps drift check end-to-end.\n- `/simplify` — review each `SKILL.md` + reference doc for duplication, dead links, bloat.\n- `/api-surface-audit` — confirm no public-API drift (no `src/` changes expected).\n- `git-commit-push` — stage each of the 5 commit slices and open the PR.\n- `github-push-fix-workflows` — if CI surfaces anything on the Phase 4b PR.\n- `plan-resolve-questions` — auto-fires after `ExitPlanMode` to walk the unresolved questions below.\n- `plan-to-github-issue` — auto-fires after `ExitPlanMode`; creates issue #N + writes branch git-config pointer.\n\n## Answered questions\n\n1. **Auto-trigger scope for `zod-nest` skill** → **Narrow: controllers + DTOs only.** Auto-trigger on `*.controller.ts` / `*.dto.ts` files that import from `zod-nest`. Module + main files reached via slash `/zod-nest` only.\n2. **`nestjs-zod-fork` handling** → **Drop from pitfalls entirely.** It's a private fork; the public skill never mentions it. Update: `skills/zod-nest-migrate/references/pitfalls.md` does NOT include a fork entry. Audit step does not check for `nestjs-zod-*` variants beyond the upstream package name.\n3. **GitHub URL pinning** → **`blob/main/` always.** All cross-repo links in `skills/<name>/**` use `https://github.com/rodrigowbazevedo/zod-nest/blob/main/<path>`. Content drift is the user's signal to re-read canonical docs.\n","reactions":{"url":"https://api.github.com/repos/rodrigowbazevedo/zod-nest/issues/32/reactions","total_count":0,"+1":0,"-1":0,"laugh":0,"hooray":0,"confused":0,"heart":0,"rocket":0,"eyes":0},"timeline_url":"https://api.github.com/repos/rodrigowbazevedo/zod-nest/issues/32/timeline","performed_via_github_app":null,"state_reason":"completed","pinned_comment":null,"score":1.0},{"url":"https://api.github.com/repos/nestjs/nest/issues/16947","repository_url":"https://api.github.com/repos/nestjs/nest","labels_url":"https://api.github.com/repos/nestjs/nest/issues/16947/labels{/name}","comments_url":"https://api.github.com/repos/nestjs/nest/issues/16947/comments","events_url":"https://api.github.com/repos/nestjs/nest/issues/16947/events","html_url":"https://github.com/nestjs/nest/issues/16947","id":4440307119,"node_id":"I_kwDOBNMhFM8AAAABCKm1rw","number":16947,"title":"core@11.1.20 regression: silent hang (exit 0) when the same provider class is declared in multiple modules with different import scopes","user":{"login":"luisalonsorios","id":180202724,"node_id":"U_kgDOCr2s5A","avatar_url":"https://avatars.githubusercontent.com/u/180202724?v=4","gravatar_id":"","url":"https://api.github.com/users/luisalonsorios","html_url":"https://github.com/luisalonsorios","followers_url":"https://api.github.com/users/luisalonsorios/followers","following_url":"https://api.github.com/users/luisalonsorios/following{/other_user}","gists_url":"https://api.github.com/users/luisalonsorios/gists{/gist_id}","starred_url":"https://api.github.com/users/luisalonsorios/starred{/owner}{/repo}","subscriptions_url":"https://api.github.com/users/luisalonsorios/subscriptions","organizations_url":"https://api.github.com/users/luisalonsorios/orgs","repos_url":"https://api.github.com/users/luisalonsorios/repos","events_url":"https://api.github.com/users/luisalonsorios/events{/privacy}","received_events_url":"https://api.github.com/users/luisalonsorios/received_events","type":"User","user_view_type":"public","site_admin":false},"labels":[],"state":"closed","locked":false,"assignees":[],"milestone":null,"comments":1,"created_at":"2026-05-13T18:35:24Z","updated_at":"2026-05-14T08:24:43Z","closed_at":"2026-05-14T08:24:43Z","assignee":null,"author_association":"NONE","issue_field_values":[],"type":null,"active_lock_reason":null,"sub_issues_summary":{"total":0,"completed":0,"percent_completed":0},"issue_dependencies_summary":{"blocked_by":0,"total_blocked_by":0,"blocking":0,"total_blocking":0},"body":"# Bug Report\n\n## Current behavior\n\nIn `@nestjs/core@11.1.20` (regression vs `11.1.19`), bootstrapping a NestJS app **hangs silently** — no error is logged, `Promise.all` in the instance loader never resolves, and because no I/O keeps the event loop alive the process exits cleanly with code `0` after `InstanceLoader` has printed `<module> dependencies initialized` for most modules but a few are left pending.\n\nThe trigger is a common pattern that worked in `11.1.19` and many prior 11.x versions: **the same `@Injectable()` class is declared as a `providers:` entry in two (or more) modules whose `imports:` graphs differ**.\n\nConcretely, in our service, `CreateModule` declares `PhotoAssignmentService` (and 7 other services) in its `providers[]` and `exports[]`. Several other feature modules (`UpdatePhotosModule`, `CreateComboSectionsModule`, `RecipeProductionSaveSuppliesModule`, etc.) also declare the same classes in their own `providers[]` rather than importing `CreateModule`. Those modules import a different (smaller) set of modules; the shared dependencies of the duplicated provider (e.g. `ProductRepository`) come from a `@Global()` module.\n\nUnder `11.1.19` this works (each module gets its own instance, dependencies are looked up via the global graph). Under `11.1.20` it deadlocks.\n\n## Minimal reproduction\n\n```ts\nimport { Global, Injectable, Module } from '@nestjs/common';\nimport { NestFactory } from '@nestjs/core';\n\n@Injectable() class Logger {}\n\n@Global()\n@Module({ providers: [Logger], exports: [Logger] })\nclass GlobalDepsModule {}\n\n@Injectable() class SharedService { constructor(public logger: Logger) {} }\n\n// Module A declares SharedService and exports it\n@Module({ providers: [SharedService], exports: [SharedService] })\nclass ModuleA {}\n\n// Module B *re-declares* the same class in its own providers[]\n// (without importing ModuleA). Logger comes from the @Global module.\n@Module({ providers: [SharedService] })\nclass ModuleB {}\n\n@Module({ imports: [GlobalDepsModule, ModuleA, ModuleB] })\nclass AppModule {}\n\nawait NestFactory.create(AppModule);\n```\n\n- `@nestjs/core@11.1.19` + `@nestjs/common@11.1.19`: bootstrap completes normally.\n- `@nestjs/core@11.1.20` + `@nestjs/common@11.1.19` (or `11.1.20`): bootstrap hangs after `InstanceLoader` logs for the other modules, never reaches `onModuleInit`, and the process exits with code `0` once the event loop empties.\n\n## Root cause (located in the diff)\n\nTwo changes shipped together in `11.1.20` and interact badly:\n\n### 1. New `Barrier` helper (`packages/core/helpers/barrier.ts`)\n\n```js\nclass Barrier {\n    constructor(targetCount) { this.currentCount = 0; this.targetCount = targetCount; ... }\n    signal() {\n        this.currentCount += 1;\n        if (this.currentCount === this.targetCount) this.resolve();\n    }\n    async signalAndWait() { this.signal(); return this.wait(); }\n}\n```\n\nA counter that requires exactly `targetCount` signals to release waiters. **One missing signal = forever-pending promise.**\n\n### 2. New `shouldSkipProviderLoading` early-return in `loadProvider` (`packages/core/injector/injector.ts`)\n\n```js\n// v20 — injector.js:101\nasync loadProvider(wrapper, moduleRef, resolutionContext = { contextId: STATIC_CONTEXT }) {\n    if (this.shouldSkipProviderLoading(wrapper, resolutionContext)) {\n        return;   // ← early return without calling loadInstance\n    }\n    const providers = moduleRef.providers;\n    await this.loadInstance(wrapper, providers, moduleRef, resolutionContext);\n    ...\n}\n\n// v20 — injector.js:502\nshouldSkipProviderLoading(wrapper, resolutionContext) {\n    const isStaticContext = resolutionContext.contextId === STATIC_CONTEXT;\n    const hasNoInquirer = !resolutionContext.inquirer;\n    const isTopLevelStaticTransientOrRequestProvider = hasNoInquirer && (wrapper.isTransient || wrapper.scope === Scope.REQUEST);\n    const isStaticInquirerOutsideResolutionContext = !!resolutionContext.inquirer &&\n        !this.isInContext(resolutionContext.inquirer, this.createResolutionContext(resolutionContext.contextId, resolutionContext.inquirer));\n    const shouldSkipForStaticBootstrap = isStaticContext &&\n        (isTopLevelStaticTransientOrRequestProvider || isStaticInquirerOutsideResolutionContext);\n    return !isSnapshotGraphCompilation && shouldSkipForStaticBootstrap;\n}\n```\n\nIn `11.1.19`, `loadProvider` unconditionally called `loadInstance`. The early-return is new in `11.1.20`.\n\n### How the hang occurs\n\n`resolveConstructorParams` (v20, `injector.js:118`) does:\n\n```js\nconst paramBarrier = new Barrier(dependencies.length);\nlet isResolved = true;\nconst resolveParam = async (param, index) => {\n    try {\n        ...\n        const paramWrapper = await this.resolveSingleParam(...);                          // (1)\n        await paramBarrier.signalAndWait();                                               // (2)\n        const paramWrapperWithInstance = await this.resolveComponentHost(...);            // (3) → loadProvider with inquirer = the outer wrapper\n        const instanceHost = paramWrapperWithInstance.getInstanceByContextId(...);\n        if (!instanceHost.isResolved && !paramWrapperWithInstance.forwardRef) {\n            isResolved = false;                                                           // (4) silent failure flag\n        }\n        return instanceHost?.instance;\n    } catch (err) { paramBarrier.signal(); ... }\n};\nconst instances = await Promise.all(dependencies.map(resolveParam));\nisResolved && (await callback(instances));                                                // (5)\n```\n\nStep (3) calls `loadProvider(depWrapper, depHostModule, { inquirer: outerWrapper })`. Inside, the new `shouldSkipProviderLoading` evaluates `isStaticInquirerOutsideResolutionContext = !isInContext(outerWrapper, …)`. During bootstrap the outer wrapper is not yet marked static/in-request/lazy-transient/explicitly-requested for this context, so `isInContext` returns `false` → the predicate becomes `true` → **`loadProvider` returns early without calling `loadInstance`**.\n\nConsequence:\n\n- `instanceHost.isResolved` stays `false` → (4) sets `isResolved = false`.\n- In (5) the `callback(instances)` is **not invoked**.\n- The outer wrapper's `donePromise` (its `settlementSignal`) is never resolved or rejected.\n- Any other caller `await`-ing that wrapper's instance hangs forever.\n- `Promise.all` in `instance-loader.createInstances` for that module never settles.\n- `NestFactory.create()` never returns.\n- No I/O handles → event loop empties → process exits with code `0`.\n\nIn `11.1.19` the same path either successfully created the instance (correct outcome for `@Global()` deps), or threw a clear `Nest can't resolve dependencies of ...` error. Either way the promise settled.\n\n## Expected behavior\n\nEither:\n\n1. The pattern works as it did in `11.1.19` (each module gets its own instance; dependencies resolved via the global graph).\n2. Or it fails fast with a descriptive error, *not* a silent hang + exit `0`.\n\nA silent forever-pending promise + clean exit is the worst possible failure mode for diagnosing this — there is no stack trace, no error, no message; users learn about it only by adding instrumentation inside `node_modules`.\n\n## Environment\n\n- `@nestjs/core` 11.1.20 (regression) vs 11.1.19 (works)\n- `@nestjs/common` 11.1.19 / 11.1.20 (either)\n- `@nestjs/microservices` 11.1.19 / 11.1.20 (either)\n- `@nestjs/platform-fastify` 11.1.20\n- Node.js v24.15.0 (also reproduces on v22)\n- pnpm 11.1.0\n- TypeScript 6.0.3, ESM (`\"module\": \"NodeNext\"`)\n\n## Workaround\n\nPin `@nestjs/core` to `11.1.19` explicitly in `dependencies` (pinning only `@nestjs/common`/`@nestjs/microservices` is not enough — without an explicit pin, pnpm resolves `@nestjs/core` to the latest matching peer range and picks `11.1.20`):\n\n```json\n\"@nestjs/common\": \"11.1.19\",\n\"@nestjs/core\": \"11.1.19\",\n\"@nestjs/microservices\": \"11.1.19\",\n```\n\n## Suggested fix direction\n\n`shouldSkipProviderLoading` returning `true` should not leave the wrapper in a permanently unsettled state. Either:\n\n- Don't skip in this branch (i.e. tighten `isStaticInquirerOutsideResolutionContext` so it only matches the cases it was designed for), or\n- If skipping is correct, mark the wrapper's `settlementSignal` as completed (resolved or rejected with a clear message) before returning, so any awaiter unblocks.\n\nHappy to test a fix against our reproduction.\n","reactions":{"url":"https://api.github.com/repos/nestjs/nest/issues/16947/reactions","total_count":4,"+1":4,"-1":0,"laugh":0,"hooray":0,"confused":0,"heart":0,"rocket":0,"eyes":0},"timeline_url":"https://api.github.com/repos/nestjs/nest/issues/16947/timeline","performed_via_github_app":null,"state_reason":"completed","pinned_comment":null,"score":1.0},{"url":"https://api.github.com/repos/devonfw/IDEasy/issues/1886","repository_url":"https://api.github.com/repos/devonfw/IDEasy","labels_url":"https://api.github.com/repos/devonfw/IDEasy/issues/1886/labels{/name}","comments_url":"https://api.github.com/repos/devonfw/IDEasy/issues/1886/comments","events_url":"https://api.github.com/repos/devonfw/IDEasy/issues/1886/events","html_url":"https://github.com/devonfw/IDEasy/issues/1886","id":4376090899,"node_id":"I_kwDOKUA_sM8AAAABBNXZEw","number":1886,"title":"NpmBasedCommandlet shows wrong tool version after install","user":{"login":"AdemZarrouki","id":81715160,"node_id":"MDQ6VXNlcjgxNzE1MTYw","avatar_url":"https://avatars.githubusercontent.com/u/81715160?v=4","gravatar_id":"","url":"https://api.github.com/users/AdemZarrouki","html_url":"https://github.com/AdemZarrouki","followers_url":"https://api.github.com/users/AdemZarrouki/followers","following_url":"https://api.github.com/users/AdemZarrouki/following{/other_user}","gists_url":"https://api.github.com/users/AdemZarrouki/gists{/gist_id}","starred_url":"https://api.github.com/users/AdemZarrouki/starred{/owner}{/repo}","subscriptions_url":"https://api.github.com/users/AdemZarrouki/subscriptions","organizations_url":"https://a