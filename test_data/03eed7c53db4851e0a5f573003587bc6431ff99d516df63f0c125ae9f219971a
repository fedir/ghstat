te = injectActivatedRoute();\r\n  constructor() {\r\n    this._router.events\r\n      .pipe(\r\n        filter((e) => e.type === EventType.NavigationEnd || e.type === EventType.NavigationSkipped),\r\n        takeUntilDestroyed()\r\n      )\r\n      .subscribe((e) => {\r\n        if (!(e as NavigationEnd | NavigationSkipped).url.endsWith(this.endsWith) || this.commands.length === 0) return;\r\n        this._router.navigate(this.commands, { relativeTo: this._route });\r\n      });\r\n  }\r\n}\r\n```\r\n\r\nThe problem is that this will break clicking the browser's back button and you have to use a different link to get to a different page\n\n### I would be willing to submit a PR to fix this issue\n\n- [X] Yes\n- [ ] No","reactions":{"url":"https://api.github.com/repos/analogjs/analog/issues/536/reactions","total_count":0,"+1":0,"-1":0,"laugh":0,"hooray":0,"confused":0,"heart":0,"rocket":0,"eyes":0},"timeline_url":"https://api.github.com/repos/analogjs/analog/issues/536/timeline","performed_via_github_app":null,"state_reason":"completed","pinned_comment":null,"score":1.0},{"url":"https://api.github.com/repos/analogjs/analog/issues/1967","repository_url":"https://api.github.com/repos/analogjs/analog","labels_url":"https://api.github.com/repos/analogjs/analog/issues/1967/labels{/name}","comments_url":"https://api.github.com/repos/analogjs/analog/issues/1967/comments","events_url":"https://api.github.com/repos/analogjs/analog/issues/1967/events","html_url":"https://github.com/analogjs/analog/issues/1967","id":3648194179,"node_id":"I_kwDOHnhHGM7ZcwaD","number":1967,"title":"Analog Router missing server entrypoint","user":{"login":"ashley-hunter","id":20795331,"node_id":"MDQ6VXNlcjIwNzk1MzMx","avatar_url":"https://avatars.githubusercontent.com/u/20795331?v=4","gravatar_id":"","url":"https://api.github.com/users/ashley-hunter","html_url":"https://github.com/ashley-hunter","followers_url":"https://api.github.com/users/ashley-hunter/followers","following_url":"https://api.gith