ote_addr;\nproxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;\nproxy_set_header X-Forwarded-Proto $scheme;\nproxy_set_header X-Scheme $scheme;\nproxy_set_header X-Forwarded-Uri $request_uri;\n```\nAnd in the app i have a simple rate-limit function\n\n```go\nrouter := fiber.New(fiber.Config{\n\t\tProxyHeader:  \"X-Real-IP\",\n\t\tTrustProxy:   true,\n\t\tTrustProxyConfig: fiber.TrustProxyConfig{\n\t\t\tLoopback: true,\n\t\t\tPrivate:  true,\n\t\t},\n\t})\n\nrouter.Use(logger.New(logger.Config{\n\t\tFormat: \"[${time}] ${ip} - ${status} - ${latency} - ${protocol}  ${method}  ${url} - ${error}\\n\",\n\t\tStream: os.Stdout,\n\t\tNext: func(f fiber.Ctx) bool {\n\t\t\treturn websocket.IsWebSocketUpgrade(f) || f.IsWebSocket() || f.Path() == strings.TrimRight(c.Config.API.Path, \"/\")+\"/health\"\n\t\t},\n}))\n\nws := router.Group(c.Config.API.PathWS)\nws.Use(\"/\", func(f fiber.Ctx) error {})\nws.Get(\"/\", func(f fiber.Ctx) error {\n\n\t\tif websocket.IsWebSocketUpgrade(f) {\n\t\t\treturn f.Next()\n\t\t}\n\t\treturn fiber.ErrUpgradeRequired\n\t}, handler.Events())\n\napi := router.Group(c.Config.API.Path)\napi.Use(handler.RateLimit)\n```\n\n```go\nfunc (c *Config) RateLimit(f fiber.Ctx) error {\n\n\tif !c.Config.API.RateLimit.Enabled || websocket.IsWebSocketUpgrade(f) || f.IsWebSocket() {\n\n\t\treturn f.Next()\n\t}\n\n\tguestIP := f.IP()\n\tlog.Println(\"_\" + guestIP + \"_\")\n       \n       // the rest of the logic for either update or add the values / guest\n}\n\nfunc (c *Config) CleanupRateLimits() {\n\n\tif !c.Config.API.RateLimit.Enabled {\n\t\treturn\n\t}\n\n\t// logic here to the 'removed' variable\n\n\tfor _, addr := range removed {\n\n\t\tc.Log.Add(logging.Entry{\n\t\t\tNotice: fmt.Sprintf(\"-> Guest '%s' was automatically cleaned out\", addr),\n\t\t})\n\t}\n}\n\n```\nI have added some logging to debug it further, and from time to time i see this in the logs\n\n> 2026/04/10 04:04:32 _54.37.168.222_\n> 2026/04/10 04:05:03 _89.125.209.209_\n> [04:05:03] 89.125.209.209 - 404 -     151.407µs - HTTP/1.1  GET  /xmlrpc.php - -\n> 2026/04/10 04:05:25 _165.227.7.228_\n> [04:05:25] 165.227.7.228 - 404 -     165.952µs - HTTP/1.1  GET  /xmlrpc.php - -\n> [04:05:26] 165.227.7.228 - 404 -     110.085µs - HTTP/1.1  GET  /wp-login.php - -\n> 2026/04/10 04:05:26 _165.227.7.228_\n> 2026/04/10 05:05:26 [HANDLERS/RATE_LIMIT:232] -> Guest '54.37.168.222' was automatically cleaned out\n> 2026/04/10 05:05:26 [HANDLERS/RATE_LIMIT:232] -> Guest '89.125.209.209' was automatically cleaned out\n> 2026/04/10 05:05:26 [HANDLERS/RATE_LIMIT:232] -> Guest 'websocket.228' was automatically cleaned out\n\nSomehow the value of `f.IP() `is becoming `websocket.228 ` and my assumption is that would be for the `165.227.7.228 ` IP as the other ones above were correctly addressed. I really can not understand what is this exactly.\n\n### How to Reproduce\n\n> Code added above\n\n### Expected Behavior\n\nReturning the correct IP value\n\n### Fiber Version\n\nv3.1.0\n\n### Code Snippet (optional)\n\n```go\npackage main\n\nimport \"github.com/gofiber/fiber/v3\"\nimport \"log\"\n\nfunc main() {\n  app := fiber.New()\n\n  // Steps to reproduce\n\n  log.Fatal(app.Listen(\":3000\"))\n}\n```\n\n### Checklist:\n\n- [x] I agree to follow Fiber's [Code of Conduct](https://github.com/gofiber/fiber/blob/main/.github/CODE_OF_CONDUCT.md).\n- [x] I have checked for existing issues that describe my problem prior to opening this one.\n- [x] I understand that improperly formatted bug reports may be closed without explanation.","reactions":{"url":"https://api.github.com/repos/gofiber/contrib/issues/1800/reactions","total_count":2,"+1":0,"-1":0,"laugh":0,"hooray":0,"confused":0,"heart":0,"rocket":0,"eyes":2},"timeline_url":"https://api.github.com/repos/gofiber/contrib/issues/1800/timeline","performed_via_github_app":null,"state_reason":"completed","pinned_comment":null,"score":1.0},{"url":"https://api.github.com/repos/gofiber/fiber/issues/4229","repository_url":"https://api.github.com/repos/gofiber/fiber","labels_url":"https://api.github.com/repos/gofiber/fiber/issues/4229/labels{/name}","comments_url":"https://api.github.com/repos/gofiber/fiber/issues/4229/comments","events_url":"https://api.github.com/repos/gofiber/fiber/issues/4229/events","html_url":"https://github.com/gofiber/fiber/issues/4229","id":4320947542,"node_id":"I_kwDODfYWS88AAAABAYxtVg","number":4229,"title":"[v3] Group(\"\", mw) empty-prefix silently propagates middleware to ALL subsequent routes on parent router","user":{"login":"salimertan","id":195414005,"node_id":"U_kgDOC6XH9Q","avatar_url":"https://avatars.githubusercontent.com/u/195414005?v=4","gravatar_id":"","url":"https://api.github.com/users/salimertan","html_url":"https://github.com/salimertan","followers_url":"https://api.github.com/users/salimertan/followers","following_url":"https://api.github.com/users/salimertan/following{/other_user}","gists_url":"https://api.github.com/users/salimertan/gists{/gist_id}","starred_url":"https://api.github.com/users/salimertan/starred{/owner}{/repo}","subscriptions_url":"https://api.github.com/users/salimertan/subscriptions","organizations_url":"https://api.github.com/users/salimertan/orgs","repos_url":"https://api.github.com/users/salimertan/repos","events_url":"https://api.github.com/users/salimertan/events{/privacy}","received_events_url":"https://api.github.com/users/salimertan/received_events","type":"User","user_view_type":"public","site_admin":false},"labels":[{"id":2064310319,"node_id":"MDU6TGFiZWwyMDY0MzEwMzE5","url":"https://api.github.com/repos/gofiber/fiber/labels/%E2%98%A2%EF%B8%8F%20Bug","name":"☢️ Bug","color":"e11d21","default":false,"description":""},{"id":2454859105,"node_id":"MDU6TGFiZWwyNDU0ODU5MTA1","url":"https://api.github.com/repos/gofiber/fiber/labels/%F0%9F%A7%B9%20Invalid","name":"🧹 Invalid","color":"ffffff","default":false,"description":""},{"id":3947514349,"node_id":"LA_kwDODfYWS87rSknt","url":"https://api.github.com/repos/gofiber/fiber/labels/v3","name":"v3","color":"436eee","default":false,"description":""}],"state":"closed","locked":false,"assignees":[],"milestone":{"url":"https://api.github.com/repos/gofiber/fiber/milestones/16","html_url":"https://github.com/gofiber/fiber/milestone/16","labels_url":"https://api.github.com/repos/gofiber/fiber/milestones/16/labels","id":15684155,"node_id":"MI_kwDODfYWS84A71I7","number":16,"title":"v3.2.0","description":"https://github.com/gofiber/fiber/releases/tag/v3.2.0","creator":{"login":"ReneWerner87","id":7063188,"node_id":"MDQ6VXNlcjcwNjMxODg=","avatar_url":"https://avatars.githubusercontent.com/u/7063188?v=4","gravatar_id":"","url":"https://api.github.com/users/ReneWerner87","html_url":"https://github.com/ReneWerner87","followers_url":"https://api.github.com/users/ReneWerner87/followers","following_url":"https://api.github.com/users/ReneWerner87/following{/other_user}","gists_url":"https://api.github.com/users/ReneWerner87/gists{/gist_id}","starred_url":"https://api.github.com/users/ReneWerner87/starred{/owner}{/repo}","subscriptions_url":"https://api.github.com/users/ReneWerner87/subscriptions","organizations_url":"https://api.github.com/users/ReneWerner87/orgs","repos_url":"https://api.github.com/users/ReneWerner87/repos","events_url":"https://api.github.com/users/ReneWerner87/events{/privacy}","received_events_url":"https://api.github.com/users/ReneWerner87/received_events","type":"User","user_view_type":"public","site_admin":false},"open_issues":0,"closed_issues":93,"state":"closed","created_at":"2026-04-25T10:53:13Z","updated_at":"2026-04-25T10:59:04Z","due_on":"2026-04-25T00:00:00Z","closed_at":"2026-04-25T10:58:51Z"},"comments":3,"created_at":"2026-04-24T06:14:42Z","updated_at":"2026-04-25T10:53:25Z","closed_at":"2026-04-24T07:50:17Z","assignee":null,"author_association":"NONE","issue_field_values":[],"type":null,"active_lock_reason":null,"sub_issues_summary":{"total":0,"completed":0,"percent_completed":0},"issue_dependencies_summary":{"blocked_by":0,"total_blocked_by":0,"blocking":0,"total_blocking":0},"body":"### Environment\n\n- Fiber: v3.1.0\n- Go: 1.26.2\n- OS: macOS ARM64 / linux/amd64\n\n### Description\n\nWhen `router.Group(\"\", mw)` is called with an **empty string prefix** and a middleware handler, Fiber v3 registers the middleware via `methodUse` against the parent router's prefix. This causes the middleware to be applied to **every route registered afterward on that parent router**, regardless of whether those routes were registered through the empty-prefix group or directly on the parent.\n\nThis is distinct from the general prefix-matching behaviour discussed in #3639. The issue is specifically about the **empty string `\"\"`** — a common pattern used to group routes without adding a path prefix while still attaching middleware — silently stacking middleware onto sibling routes that share the same parent.\n\n### Minimum Reproducible Example\n\n```go\npackage main\n\nimport (\n    \"fmt\"\n    \"net/http/httptest\"\n    \"sync/atomic\"\n\n    \"github.com/gofiber/fiber/v3\"\n)\n\nfunc main() {\n    var counter atomic.Int32\n\n    mw := func(c fiber.Ctx) error {\n        counter.Add(1)\n        fmt.Printf(\"mw called (total: %d)\\n\", counter.Load())\n        return c.Next()\n    }\n\n    app := fiber.New()\n    v1 := app.Group(\"/v1\")\n\n    // Group A — uses empty prefix + middleware\n    groupA := v1.Group(\"\", mw)\n    groupA.Get(\"/a\", func(c fiber.Ctx) error { return c.SendString(\"a\") })\n\n    // Group B — completely separate, registered AFTER group A\n    groupB := v1.Group(\"\", mw)\n    groupB.Get(\"/b\", func(c fiber.Ctx) error { return c.SendString(\"b\") })\n\n    // Group C — also separate\n    groupC := v1.Group(\"\", mw)\n    groupC.Get(\"/c\", func(c fiber.Ctx) error { return c.SendString(\"c\") })\n\n    // Request to /v1/c — only groupC's mw should run (counter = 1)\n    counter.Store(0)\n    req := httptest.NewRequest(\"GET\", \"/v1/c\", nil)\n    resp, _ := app.Test(req)\n    fmt.Printf(\"/v1/c → status %d, mw executions: %d (expected 1)\\n\",\n        resp.StatusCode, counter.Load())\n    // Actual: mw executions = 3 (one per Group(\"\", mw) call)\n}\n```\n\n**Expected output:**\n```\n/v1/c → status 200, mw executions: 1\n```\n\n**Actual output (v3.1.0):**\n```\nmw called (total: 1)\nmw called (total: 2)\nmw called (total: 3)\n/v1/c → status 200, mw executions: 3\n```\n\n### Root Cause Analysis\n\nIn `group.go`, `Group(prefix string, handlers ...any)` registers handlers via:\n\n```go\ngrp.app.register([]string{methodUse}, prefix, grp, converted...)\n```\n\nWhen `prefix = \"\"`, this resolves to the parent group's prefix (e.g. `/v1`). Each subsequent `Group(\"\", mw)` call adds another `methodUse` entry at `/v1`, causing every request under `/v1/*` to execute `mw` once per registered empty-prefix group.\n\n### Why This Is Non-Obvious\n\n- `Group(\"\", mw)` is a documented and idiomatic pattern to attach middleware without adding a path segment\n- The middleware stacking is invisible at registration time — no warning, no panic, no compile error\n- Unit tests and `go vet` do not catch it (single-handler test scope sees only one `mw` invocation)\n- The bug only manifests when **multiple** `Group(\"\", mw)` calls are made on the same parent, which is a natural pattern when handlers register their own routes\n\n### Downstream Impact (Real-World Example)\n\nIn a production application with a PostgreSQL connection pool (`maxConns=N`), each empty-prefix group middleware performed a `pool.Acquire()`. Three such groups stacking on a fourth handler's route caused **4 acquisitions on a pool of 3** — deterministic deadlock on every request to the fourth route.\n\n### Expected Behavior\n\n`v1.Group(\"\", mw)` should attach `mw` **only to routes registered through that specific group instance**, not to all routes sharing the parent prefix that are registered afterward.\n\n### Workaround\n\nReplace empty-prefix groups with explicit path-prefixed groups and restructure handler registration accordingly:\n\n```go\n// Instead of:\nhandlerA.RegisterRoutes(v1.Group(\"\", mw))\nhandlerB.RegisterRoutes(v1.Group(\"\", mw))\n\n// Use:\nhandlerA.RegisterRoutes(v1.Group(\"/a\", mw))\nhandlerB.RegisterRoutes(v1.Group(\"/b\", mw))\n```\n\nThis requires removing any sub-group creation inside each handler's `RegisterRoutes` to avoid double-prefixing.\n\n### Related\n\n- #3639 — General discussion of prefix-matching middleware behaviour (our issue is the specific `\"\"` empty-prefix case causing stacking)\n\n### Checklist\n\n- [x] I agree to follow Fiber's [Code of Conduct](https://github.com/gofiber/fiber/blob/main/.github/CODE_OF_CONDUCT.md).\n- [x] I have checked for existing issues that describe my problem prior to opening this one.\n- [x] I understand that improperly formatted bug reports may be closed without explanation.","reactions":{"url":"https://api.github.com/repos/gofiber/fiber/issues/4229/reactions","total_count":0,"+1":0,"-1":0,"laugh":0,"hooray":0,"confused":0,"heart":0,"rocket":0,"eyes":0},"timeline_url":"https://api.github.com/repos/gofiber/fiber/issues/4229/timeline","performed_via_github_app":null,"state_reason":"completed","pinned_comment":null,"score":1.0},{"url":"https://api.github.com/repos/golang/vulndb/issues/4534","repository_url":"https://api.github.com/repos/golang/vulndb","labels_url":"https://api.github.com/repos/golang/vulndb/issues/4534/labels{/name}","comments_url":"https://api.github.com/repos/golang/vulndb/issues/4534/comments","events_url":"https://api.github.com/repos/golang/vulndb/issues/4534/events","html_url":"https://github.com/golang/vulndb/issues/4534","id":3985804116,"node_id":"I_kwDOFV-OBs7tkotU","number":4534,"title":"x/vulndb: potential Go vuln in github.com/gofiber/fiber/v3: GHSA-2mr3-m5q5-wgp6","user":{"login":"GoVulnBot","id":96493708,"node_id":"U_kgDOBcBgjA","avatar_url":"https://avatars.githubusercontent.com/u/96493708?v=4","gravatar_id":"","url":"https://api.github.com/users/G