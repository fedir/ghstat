eRedirect)\n\tapp.Post(\"/login\", handleLogin)\n\n\tapp.Listen(\":3000\")\n}\n\nfunc handleRedirect(c *fiber.Ctx) error {\n\t// Attacker-controlled input from query parameter\n\ttargetURL := c.Query(\"url\")\n\n\t// VULNERABLE: No validation or sanitization\n\t// Directly redirect to user-supplied URL\n\treturn c.Redirect(targetURL, fiber.StatusFound)\n}\n\nfunc handleLogin(c *fiber.Ctx) error {\n\ttype LoginRequest struct {\n\t\tUsername   string `json:\"username\"`\n\t\tPassword   string `json:\"password\"`\n\t\tRedirectTo string `json:\"redirect_to\"`\n\t}\n\n\tvar req LoginRequest\n\tif err := c.BodyParser(&req); err != nil {\n\t\treturn c.Status(400).JSON(fiber.Map{\"error\": \"invalid request\"})\n\t}\n\n\t// Simulate authentication (hardcoded for demo)\n\tif req.Username == \"admin\" && req.Password == \"password123\" {\n\t\t// VULNERABLE: Attacker-controlled redirect_to flows directly to Redirect()\n\t\t// An attacker can POST with redirect_to: \"https://evil.com/phishing\"\n\t\treturn c.Redirect(req.RedirectTo, fiber.StatusFound)\n\t}\n\n\treturn c.Status(401).JSON(fiber.Map{\"error\": \"invalid credentials\"})\n}\n```\n\nRun: `vow check test_file.go`\n\n**Expected:** `open redirect` flagged as High/Critical\n**Actual:** Trust score 100%, 0 issues detected\n\n## Impact\n**High** — `open redirect` is a real-world vulnerability that vow should detect in Go projects.\n\n---\n*Auto-filed by vow daily gap scanner (Claude-driven)*","reactions":{"url":"https://api.github.com/repos/guanchuan1314/vow/issues/931/reactions","total_count":0,"+1":0,"-1":0,"laugh":0,"hooray":0,"confused":0,"heart":0,"rocket":0,"eyes":0},"timeline_url":"https://api.github.com/repos/guanchuan1314/vow/issues/931/timeline","performed_via_github_app":null,"state_reason":"completed","pinned_comment":null,"score":1.0},{"url":"https://api.github.com/repos/cajasmota/archigraph/issues/311","repository_url":"https://api.github.com/repos/cajasmota/archigraph","labels_url":"https://api.github.com/re