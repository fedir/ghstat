 most specific layer.\r\n\r\nnode.js version: v12.18.3\r\nnpm/yarn and version: 6.14.6\r\n`@koa/router` version: 9.4.0\r\n`koa` version: 2.13.0\r\n\r\n#### Code sample:\r\n\r\n```js\r\nconst Koa = require('koa')\r\nconst Router = require('@koa/router')\r\n\r\nconst app = new Koa()\r\n\r\nconst router = new Router()\r\nrouter.get('main#info', '/info', function() {})\r\n\r\nconst nestedRouter = new Router()\r\nnestedRouter.get('nested#name', '/updates', function() {})\r\n\r\nrouter.use('/v1/api', nestedRouter.routes(), nestedRouter.allowedMethods())\r\n\r\napp.use(router.routes()).use(router.allowedMethods())\r\n\r\napp.listen(8084)\r\n\r\n```\r\n\r\n#### Expected Behavior:\r\n\r\nOnly layers with path and methods should be included in matched.pathAndMethods array.\r\n\r\n#### Actual Behavior:\r\n\r\nAny layer which matches the given path will appear in matched.pathAndMethods array. Even if the layer has zero methods associated with them.\r\n![Screen Shot 2020-09-23 at 2 57 15 PM](https://user-images.githubusercontent.com/30158849/94063186-5a0a1080-fdad-11ea-8feb-f074a68b050c.png)\r\n","reactions":{"url":"https://api.github.com/repos/koajs/router/issues/105/reactions","total_count":0,"+1":0,"-1":0,"laugh":0,"hooray":0,"confused":0,"heart":0,"rocket":0,"eyes":0},"timeline_url":"https://api.github.com/repos/koajs/router/issues/105/timeline","performed_via_github_app":null,"state_reason":"completed","pinned_comment":null,"score":1.0},{"url":"https://api.github.com/repos/koajs/koa-body/issues/200","repository_url":"https://api.github.com/repos/koajs/koa-body","labels_url":"https://api.github.com/repos/koajs/koa-body/issues/200/labels{/name}","comments_url":"https://api.github.com/repos/koajs/koa-body/issues/200/comments","events_url":"https://api.github.com/repos/koajs/koa-body/issues/200/events","html_url":"https://github.com/koajs/koa-body/issues/200","id":1125948513,"node_id":"I_kwDOAPqJEs5DHJxh","number":200,"title":"Upgrade formidable","user":{"login":"AmauryD","id":