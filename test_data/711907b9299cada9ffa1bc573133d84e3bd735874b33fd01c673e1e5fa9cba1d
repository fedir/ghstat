author_association":"NONE","issue_field_values":[],"type":null,"active_lock_reason":null,"sub_issues_summary":{"total":0,"completed":0,"percent_completed":0},"issue_dependencies_summary":{"blocked_by":0,"total_blocked_by":0,"blocking":0,"total_blocking":0},"body":"## Describe the bug\n\nThe v3.1.0 has broken the compatibility of compress.\nThe request will be blocked!\n\n**Node.js version:** v25.0.0\n\n**OS version:** win11 25h2\n\n## Code to reproduce\n\n```ts\nimport Koa from 'koa';\nimport fs from 'node:fs';\nimport compress from 'koa-compress';\n\nconst app = new Koa();\n\napp.use(\n  compress({\n    br: false\n  })\n);\n\napp.use(async ctx => {\n  ctx.type = 'application/javascript';\n  ctx.body = fs.createReadStream('index.js');\n});\n\napp.listen(3000, () => {\n  console.log(`server run at: \\x1b[36mhttp://127.0.0.1:3000\\x1b[0m`);\n});\n```\n\n## Checklist\n\n- [x] I have searched through GitHub issues for similar issues.\n- [x] I have completely read through the README and documentation.\n- [x] I have tested my code with the latest version of Node.js and this package and confirmed it is still not working.\n","reactions":{"url":"https://api.github.com/repos/koajs/koa/issues/1913/reactions","total_count":1,"+1":0,"-1":0,"laugh":0,"hooray":0,"confused":0,"heart":0,"rocket":0,"eyes":1},"timeline_url":"https://api.github.com/repos/koajs/koa/issues/1913/timeline","performed_via_github_app":null,"state_reason":"completed","pinned_comment":null,"score":1.0},{"url":"https://api.github.com/repos/koajs/koa-body/issues/238","repository_url":"https://api.github.com/repos/koajs/koa-body","labels_url":"https://api.github.com/repos/koajs/koa-body/issues/238/labels{/name}","comments_url":"https://api.github.com/repos/koajs/koa-body/issues/238/comments","events_url":"https://api.github.com/repos/koajs/koa-body/issues/238/events","html_url":"https://github.com/koajs/koa-body/issues/238","id":2883615112,"node_id":"I_kwDOAPqJEs6r4HmI","number":238,"title":"Bug: koa-body Sets ct