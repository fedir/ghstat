m/users/benbucksch/orgs","repos_url":"https://api.github.com/users/benbucksch/repos","events_url":"https://api.github.com/users/benbucksch/events{/privacy}","received_events_url":"https://api.github.com/users/benbucksch/received_events","type":"User","user_view_type":"public","site_admin":false},"author_association":"COLLABORATOR","issue_field_values":[],"type":{"id":17595929,"node_id":"IT_kwDOCYj0A84BDH4Z","name":"Bug","description":"An unexpected problem or behavior","color":"red","created_at":"2024-02-14T00:23:49Z","updated_at":"2024-07-26T14:40:26Z","is_enabled":true},"active_lock_reason":null,"sub_issues_summary":{"total":0,"completed":0,"percent_completed":0},"issue_dependencies_summary":{"blocked_by":0,"total_blocked_by":0,"blocking":0,"total_blocking":0},"body":"### Reproduction\n\n1. Go to Mail\n2. Go to the Search Tab\n3. Don't input anything in the search field\n\n### Actual Result\n\n- Switches between 0 results and some results\n- Flashes\n\n### Expected Result\n\n- No flashing\n\n### Possible Cause\n\n**Theory 1**\n\n> Consequently, there's no such thing as a \"before update\"/\"after update\" hook.\n\nhttps://svelte.dev/docs/svelte/lifecycle-hooks\n\n- In Svelte 4, before the component is mounted the function runs the first time and then the subsequent run within the given period is skipped\n- In Svelte 5, the function only runs after the function is mounted, and since the there's an update it will cause it to run again\n\n**Theory 2**\n\n> Everything in-between — when certain state is updated — is not related to the component as a whole; only the parts that need to react to the state change are notified. This is because under the hood the smallest unit of change is actually not a component, it's the (render) effects that the component sets up upon component initialization.\n\nhttps://svelte.dev/docs/svelte/lifecycle-hooks\n\n- In Svelte 4 all reactive changes are based on the component\n- In Svelte 5 all reactive changes are based signals which are independent which might be why the debounce doesn't when to skip a call\n\n### Problem Code\nhttps://github.com/mustang-im/mustang/blob/dfcebea9223191308f34085f23d220b2e766ec30/app/frontend/Mail/Search/SearchPane.svelte#L77-L78","reactions":{"url":"https://api.github.com/repos/mustang-im/mustang/issues/1203/reactions","total_count":0,"+1":0,"-1":0,"laugh":0,"hooray":0,"confused":0,"heart":0,"rocket":0,"eyes":0},"timeline_url":"https://api.github.com/repos/mustang-im/mustang/issues/1203/timeline","performed_via_github_app":null,"state_reason":"completed","pinned_comment":null,"score":1.0},{"url":"https://api.github.com/repos/cajasmota/archigraph/issues/235","repository_url":"https://api.github.com/repos/cajasmota/archigraph","labels_url":"https://api.github.com/repos/cajasmota/archigraph/issues/235/labels{/name}","comments_url":"https://api.github.com/repos/cajasmota/archigraph/issues/235/comments","events_url":"https://api.github.com/repos/cajasmota/archigraph/issues/235/events","html_url":"https://github.com/cajasmota/archigraph/issues/235","id":4412981342,"node_id":"I_kwDOSYBYgc8AAAABBwjAXg","number":235,"title":"Add SvelteKit sample app to VERIFY-2 corpus (sveltejs/kit sites/kit.svelte.dev)","user":{"login":"cajasmota","id":5105329,"node_id":"MDQ6VXNlcjUxMDUzMjk=","avatar_url":"https://avatars.githubusercontent.com/u/5105329?v=4","gravatar_id":"","url":"https://api.github.com/users/cajasmota","html_url":"https://github.com/cajasmota","followers_url":"https://api.github.com/users/cajasmota/followers","following_url":"https://api.github.com/users/cajasmota/following{/other_user}","gists_url":"https://api.github.com/users/cajasmota/gists{/gist_id}","starred_url":"https://api.github.com/users/cajasmota/starred{/owner}{/repo}","subscriptions_url":"https://api.github.com/users/cajasmota/subscriptions","organizations_url":"https://api.github.com/users/cajasmota/orgs","repos_url":"https://api.github.com/users/cajasmota/repos","events_url":"https://api.github.com/users/caj