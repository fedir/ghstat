  T: Tuple,\r\n        Self::HList: Combine<T::HList>,\r\n    {\r\n        self.hlist().combine(other.hlist()).flatten()\r\n    }\r\n}\r\n\r\npub type CombinedTuples<T, U> =\r\n    <<<T as Tuple>::HList as Combine<<U as Tuple>::HList>>::Output as HList>::Tuple;\r\n\r\n// Combines Product together.\r\npub trait Combine<T: HList> {\r\n    type Output: HList;\r\n\r\n    fn combine(self, other: T) -> Self::Output;\r\n}\r\n\r\nimpl<T: HList> Combine<T> for () {\r\n    type Output = T;\r\n\r\n    fn combine(self, other: T) -> Self::Output {\r\n        other\r\n    }\r\n}\r\n\r\nimpl<H, T: HList, U: HList> Combine<U> for Product<H, T>\r\nwhere\r\n    T: Combine<U>,\r\n    Product<H, <T as Combine<U>>::Output>: HList,\r\n{\r\n    type Output = Product<H, <T as Combine<U>>::Output>;\r\n\r\n    fn combine(self, other: U) -> Self::Output {\r\n        Product(self.0, self.1.combine(other))\r\n    }\r\n}\r\n\r\nimpl HList for () {\r\n    type Tuple = ();\r\n\r\n    fn flatten(self) -> Self::Tuple {}\r\n}\r\n\r\nimpl Tuple for () {\r\n    type HList = ();\r\n\r\n    fn hlist(self) -> Self::HList {}\r\n}\r\n\r\nimpl<T16> HList for Product<T16, ()> {\r\n    type Tuple = (T16,);\r\n\r\n    fn flatten(self) -> Self::Tuple {\r\n        (self.0,)\r\n    }\r\n}\r\nimpl<T16> Tuple for (T16,) {\r\n    type HList = Product<T16, ()>;\r\n\r\n    fn hlist(self) -> Self::HList {\r\n        Product(self.0, ())\r\n    }\r\n}\r\n\r\npub trait FilterBase {\r\n    type Extract: Tuple;\r\n}\r\n\r\npub trait Filter: FilterBase {\r\n}\r\n\r\nimpl<T: FilterBase> Filter for T {}\r\n\r\ntrait Mumbo {\r\n    type Extract;\r\n    fn mumbo(&self) -> Self::Extract;\r\n}\r\n\r\nimpl<T, U> Mumbo for (T, U)\r\nwhere\r\n    // There trait bounds are taken from `And`\r\n    T: Filter,\r\n    U: Filter,\r\n    <T::Extract as Tuple>::HList: Combine<<U::Extract as Tuple>::HList>,\r\n\r\n{\r\n    type Extract = CombinedTuples<T::Extract, U::Extract>;\r\n\r\n    fn mumbo(&self) -> Self::Extract {\r\n        unreachable!()\r\n    }\r\n}\r\n\r\npub struct Exact<P>(P);\r\n\r\nimpl<P> FilterBase for Exact<P> {\r\n    type Extract = ();\r\n}\r\n\r\nstruct Param;\r\n\r\nimpl FilterBase for Param {\r\n    type Extract = (usize,);\r\n}\r\n\r\n// Param as impl Trait\r\nfn impl_param() -> impl Filter<Extract = (usize,)> {\r\n    Param\r\n}\r\n\r\nfn main() {\r\n    let a = Exact(\"\");\r\n    let b = Param;\r\n    let c = impl_param();\r\n\r\n    (a, b).mumbo();\r\n    //           ^ (usize,)\r\n\r\n    (a, b).mumbo();\r\n    //           ^ (usize,)\r\n}\r\n\"#,\r\n    );\r\n```\r\n</details>","reactions":{"url":"https://api.github.com/repos/rust-lang/rust-analyzer/issues/4774/reactions","total_count":0,"+1":0,"-1":0,"laugh":0,"hooray":0,"confused":0,"heart":0,"rocket":0,"eyes":0},"timeline_url":"https://api.github.com/repos/rust-lang/rust-analyzer/issues/4774/timeline","performed_via_github_app":null,"state_reason":"completed","pinned_comment":null,"score":1.0},{"url":"https://api.github.com/repos/seanmonstar/warp/issues/1106","repository_url":"https://api.github.com/repos/seanmonstar/warp","labels_url":"https://api.github.com/repos/seanmonstar/warp/issues/1106/labels{/name}","comments_url":"https://api.github.com/repos/seanmonstar/warp/issues/1106/comments","events_url":"https://api.github.com/repos/seanmonstar/warp/issues/1106/events","html_url":"https://github.com/seanmonstar/warp/issues/1106","id":2561503906,"node_id":"I_kwDOCGGJKM6YrXKi","number":1106,"title":"Next release","user":{"login":"RapidPencil","id":148853841,"node_id":"U_kgDOCN9UUQ","avatar_url":"https://avatars.githubusercontent.com/u/148853841?v=4","gravatar_id":"","url":"https://api.github.com/users/RapidPencil","html_url":"https://github.com/RapidPencil","followers_url":"https://api.github.com/users/RapidPencil/followers","following_url":"https://api.github.com/users/RapidPencil/following{/other_user}","gists_url":"https://api.github.com/users/RapidPencil/gists{/gist_id}","starred_url":"https://api.github.com/users/Rap