lso have nested fixture folders that remain\nunswept; sweeping those is tracked as separate follow-up.\n\nCo-Authored-By: Claude Opus 4.7 (1M context) <noreply@anthropic.com>","tree":{"sha":"eca3855a1e5e04ddd5a4da66a28c7dd38d5e8bc1","url":"https://api.github.com/repos/analogjs/analog/git/trees/eca3855a1e5e04ddd5a4da66a28c7dd38d5e8bc1"},"url":"https://api.github.com/repos/analogjs/analog/git/commits/e16fb9523ad90b8690f0b9886379b0dcc19bf0ff","comment_count":0,"verification":{"verified":false,"reason":"unsigned","signature":null,"payload":null,"verified_at":null}},"url":"https://api.github.com/repos/analogjs/analog/commits/e16fb9523ad90b8690f0b9886379b0dcc19bf0ff","html_url":"https://github.com/analogjs/analog/commit/e16fb9523ad90b8690f0b9886379b0dcc19bf0ff","comments_url":"https://api.github.com/repos/analogjs/analog/commits/e16fb9523ad90b8690f0b9886379b0dcc19bf0ff/comments","author":{"login":"brandonroberts","id":42211,"node_id":"MDQ6VXNlcjQyMjEx","avatar_url":"https://avatars.githubusercontent.com/u/42211?v=4","gravatar_id":"","url":"https://api.github.com/users/brandonroberts","html_url":"https://github.com/brandonroberts","followers_url":"https://api.github.com/users/brandonroberts/followers","following_url":"https://api.github.com/users/brandonroberts/following{/other_user}","gists_url":"https://api.github.com/users/brandonroberts/gists{/gist_id}","starred_url":"https://api.github.com/users/brandonroberts/starred{/owner}{/repo}","subscriptions_url":"https://api.github.com/users/brandonroberts/subscriptions","organizations_url":"https://api.github.com/users/brandonroberts/orgs","repos_url":"https://api.github.com/users/brandonroberts/repos","events_url":"https://api.github.com/users/brandonroberts/events{/privacy}","received_events_url":"https://api.github.com/users/brandonroberts/received_events","type":"User","user_view_type":"public","site_admin":false},"committer":{"login":"brandonroberts","id":42211,"node_id":"MDQ6VXNlcjQyMjEx","avatar_url":"https://avatars.g