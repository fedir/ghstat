 AC1\" || echo \"FAIL: AC1\"\n\n# AC2: tested_spec_kit ブロック\nrg -n \"tested_spec_kit:\" docs/dev/spec-kit-override-investigation.md && \\\nrg -n \"specify_cli_version|source_tag_or_commit|install_method|checked_at|integration\" docs/dev/spec-kit-override-investigation.md && echo \"PASS: AC2\" || echo \"FAIL: AC2\"\n\n# AC3: 5機構比較（runtime / install-time 区別含む）\nrg -n \"project-local template overrides|preset-provided files|extension-provided files|extension hooks|installed command registration|command snapshot overrides\" docs/dev/spec-kit-override-investigation.md && \\\nrg -n \"runtime|install[- ]time\" docs/dev/spec-kit-override-investigation.md && echo \"PASS: AC3\" || echo \"FAIL: AC3\"\n\n# AC4: 二つの matrix 分離\nrg -n \"Template resolution matrix|Command behavior.*matrix|Command behavior / registration matrix\" docs/dev/spec-kit-override-investigation.md && \\\nrg -n \"spec-template|plan-template|tasks-template|constitution-template\" docs/dev/spec-kit-override-investigation.md && \\\nrg -n \"/constitution|/specify|/plan|/tasks|/taskstoissues|/implement\" docs/dev/spec-kit-override-investigation.md && echo \"PASS: AC4\" || echo \"FAIL: AC4\"\n\n# AC4b: spec-kit#2278 回帰確認\nrg -n \"spec-kit#2278|spec-kit/issues/2278\" docs/dev/spec-kit-override-investigation.md && \\\nrg -n \"setup-tasks\\.sh|resolve_template.*tasks-template|TASKS_TEMPLATE\" docs/dev/spec-kit-override-investigation.md && echo \"PASS: AC4b\" || echo \"FAIL: AC4b\"\n\n# AC5: docs canonical boundary（derived pointer default）\nrg -n \"derived pointer.*default|Recommended default.*derived pointer|derived pointer.*維持\" docs/dev/spec-kit-override-investigation.md && \\\nrg -n \"完全排除|eliminate|alternative\" docs/dev/spec-kit-override-investigation.md && echo \"PASS: AC5\" || echo \"FAIL: AC5\"\n\n# AC6: follow-up decision\nrg -n \"ADR 0002 追補|ADR 追補|follow-up Implementation Issue|Allowed Paths|Stop Conditions\" docs/dev/spec-kit-override-investigation.md && echo \"PASS: AC6\" || echo \"FAIL: AC6\"\n\n# AC7: 