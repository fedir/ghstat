 rocket_db_pools, sqlx, and postgres. Using sqlx 0.7 everything work as expected. However, given the CVE in 0.7 I attempted to upgrade to 0.8. Unfortunately I get the following error:\r\n\r\n`error[E0277]: the trait bound `&mut rocket_db_pools::sqlx::PgConnection: sqlx::Executor<'_>` is not satisfied\r\n   --> backend/src/models/device.rs:22:24\r\n    |\r\n22  |             .fetch_all(db)\r\n    |              --------- ^^ the trait `sqlx::Executor<'_>` is not implemented for `&mut rocket_db_pools::sqlx::PgConnection`\r\n    |              |\r\n    |              required by a bound introduced by this call\r\n    |\r\n    = help: the following other types implement trait `sqlx::Executor<'c>`:\r\n              `&'c mut AnyConnection` implements `sqlx::Executor<'c>`\r\n              `&'c mut sqlx::PgConnection` implements `sqlx::Executor<'c>`\r\n              `&'c mut sqlx::sqlx_postgres::PgListener` implements `sqlx::Executor<'c>`\r\n              `&sqlx::Pool<DB>` implements `sqlx::Executor<'p>`\r\nnote: required by a bound in `sqlx::query::QueryAs::<'q, DB, O, A>::fetch_all``\r\n\r\nIt's my understanding that rocket_db_pools::sqlx is just a reexport of sqlx, so technically the compiler telling me that sqlx::PgConnection implements the Executor trait when rocket_db_pools::sqlx::PgConnction doesn't is very confusing to me.\r\n\r\n\r\n\r\n### Test Case\r\n\r\n```rust\r\nUnable to write a test for this as it's failing to compile. Here's a simplified version of my app that compiles w/sqlx 0.7 but fail with sqlx 0.8\r\n\r\n`\r\n#[macro_use] extern crate rocket;\r\n\r\nuse anyhow::Result;\r\nuse rocket::{response, routes, Build, Request, Rocket};\r\nuse rocket_db_pools::sqlx::PgPool;\r\nuse rocket_db_pools::{Connection, Database};\r\nuse rocket::http::Status;\r\nuse rocket::response::Responder;\r\nuse rocket::serde::json::serde_json::json;\r\nuse rocket::serde::json::{serde_json, Value};\r\nuse rocket::serde::{Deserialize, Serialize};\r\nuse thiserror::Error;\r\n\r\n#[launch]\r\nasync fn launch() -> _ {\r\n    rocket()\r\n}\r\n\r\n#[derive(Database)]\r\n#[database(\"rocket_db_test\")]\r\npub struct RocketDbtestDb(PgPool);\r\n\r\n#[get(\"/api/devices\")]\r\npub async fn get_all(db: Connection<RocketDbtestDb>) -> Result<Value, AppError> {\r\n    Ok(json!(Device::get_all(db).await?))\r\n}\r\n\r\n#[derive(Serialize, Deserialize, Debug, sqlx::FromRow)]\r\npub struct Device {\r\n    pub id: i64,\r\n    pub name: Option<String>,\r\n    pub mac_addr: String,\r\n    pub manufacturer: Option<String>,\r\n    pub ip_addr: Option<String>,\r\n}\r\n\r\nimpl Device {\r\n    pub async fn get_all(mut db: Connection<RocketDbtestDb>) -> Result<Vec<Device>> {\r\n        let db = &mut **db;\r\n        Ok(sqlx::query_as::<_, Device>(\"SELECT * from devices\")\r\n            .fetch_all(db)\r\n            .await?)\r\n    }\r\n}\r\n\r\npub fn rocket() -> Rocket<Build> {\r\n    let rocket = rocket::build();\r\n\r\n    rocket\r\n        .attach(RocketDbtestDb::init())\r\n        .mount(\r\n            \"/\",\r\n            routes![\r\n                get_all,\r\n            ],\r\n        )\r\n}\r\n\r\n#[derive(Error, Debug)]\r\npub enum AppError {\r\n    #[error(transparent)]\r\n    Io(#[from] std::io::Error),\r\n\r\n    #[error(transparent)]\r\n    Basic(#[from] Box<dyn std::error::Error>),\r\n\r\n    #[error(transparent)]\r\n    Db(#[from] sqlx::Error),\r\n\r\n    #[error(transparent)]\r\n    Client(#[from] serde_json::Error),\r\n\r\n    #[error(transparent)]\r\n    Anyhow(#[from] anyhow::Error),\r\n\r\n    #[error(\"invalid authentication, bad user\")]\r\n    AuthError(String),\r\n}\r\n\r\nimpl<'r, 'o: 'r> Responder<'r, 'o> for AppError {\r\n    fn respond_to(self, req: &'r Request<'_>) -> response::Result<'o> {\r\n        // log `self` to your favored error tracker, e.g.\r\n        // sentry::capture_error(&self);\r\n        println!(\"Error: {}\", self);\r\n        Status::InternalServerError.respond_to(req)\r\n    }\r\n}`\r\n```\r\n\r\n\r\n### Log Output\r\n\r\n```shell\r\nThere is no test case for this as it's a compilation failure.\r\n```\r\n\r\n\r\n### Additional Context\r\n\r\n_No response_\r\n\r\n### System Checks\r\n\r\n- [X] My bug report relates to functionality.\r\n- [X] I have tested against the latest Rocket release or a recent git commit.\r\n- [X] I have tested against the latest stable `rustc` toolchain.\r\n- [X] I was unable to find this issue previously reported.","reactions":{"url":"https://api.github.com/repos/rwf2/Rocket/issues/2882/reactions","total_count":0,"+1":0,"-1":0,"laugh":0,"hooray":0,"confused":0,"heart":0,"rocket":0,"eyes":0},"timeline_url":"https://api.github.com/repos/rwf2/Rocket/issues/2882/timeline","performed_via_github_app":null,"state_reason":"completed","pinned_comment":null,"score":1.0},{"url":"https://api.github.com/repos/rwf2/Rocket/issues/2871","repository_url":"https://api.github.com/repos/rwf2/Rocket","labels_url":"https://api.github.com/repos/rwf2/Rocket/issues/2871/labels{/name}","comments_url":"https://api.github.com/repos/rwf2/Rocket/issues/2871/comments","events_url":"https://api.github.com/repos/rwf2/Rocket/issues/2871/events","html_url":"https://github.com/rwf2/Rocket/issues/2871","id":2562718992,"node_id":"I_kwDOAzqMt86Yv_0Q","number":2871,"title":"FromRequest for Option<T> should fail if from_request(...) T fails, not be None","user":{"login":"jespersm","id":664940,"node_id":"MDQ6VXNlcjY2NDk0MA==","avatar_url":"https://avatars.githubusercontent.com/u/664940?v=4","gravatar_id":"","url":"https://api.github.com/users/jespersm","html_url":"https://github.com/jespersm","followers_url":"https://api.github.com/users/jespersm/followers","following_url":"https://api.github.com/users/jespersm/following{/other_user}","gists_url":"https://api.github.com/users/jespersm/gists{/gist_id}","starred_url":"https://api.github.com/users/jespersm/starred{/owner}{/repo}","subscriptions_url":"https://api.github.com/users/jespersm/subscriptions","organizations_url":"https://api.github.com/users/jespersm/orgs","repos_url":"https://api.github.com/users/jespersm/repos","events_url":"https://api.github.com/users/jespersm/events{/privacy}","received_events_url":"https://api.github.com/users/jespersm/received_events","type":"User","user_view_type":"public","site_admin":false},"labels":[{"id":758540633,"node_id":"MDU6TGFiZWw3NTg1NDA2MzM=","url":"https://api.github.com/repos/rwf2/Rocket/labels/suggestion","name":"suggestion","color":"5319E7","default":false,"description":"A suggestion to change functionality"}],"state":"closed","locked":false,"assignees":[],"milestone":null,"comments":3,"created_at":"2024-10-02T22:13:18Z","updated_at":"2024-12-02T12:56:27Z","closed_at":"2024-12-02T12:56:14Z","assignee":null,"author_association":"NONE","issue_field_values":[],"type":null,"active_lock_reason":null,"sub_issues_summary":{"total":0,"completed":0,"percent_completed":0},"issue_dependencies_summary":{"blocked_by":0,"total_blocked_by":0,"blocking":0,"total_blocking":0},"body":"### API Docs to Existing Functionality\n\nhttps://api.rocket.rs/master/rocket/request/trait.FromRequest\n\n### Problems with Existing Functionality\n\nWhen using the FromRequest guards/extractors with an Option, there's no differentiation between a good and a bad request.\r\n\r\nImagine the following struct:\r\n\r\n```rust\r\npub struct SessionId {\r\n    session_id: u64,\r\n}\r\n\r\n#[rocket::async_trait]\r\nimpl<'r> FromRequest<'r> for SessionId {\r\n    type Error = ParseIntError;\r\n\r\n    async fn from_request(request: &'r Request<'_>) -> Outcome<Self, (Status, Error), Status> {\r\n        request.headers().get(\"Session-Id\").next()\r\n            .or_forward(Status::BadRequest)\r\n            .and_then(|v| v.parse()\r\n            .map(|id| SessionId { session_id: id })\r\n            .or_error(Status::BadRequest))\r\n    }\r\n}\r\n```\r\n\r\nLet's imagine we have a handler which can handle the 'Session-Id' header if it is sent in, but can function without:\r\n\r\n```rust\r\n#[get(\"/optional\")]\r\nfn get_data_with_opt_header(opt_header: Option<SessionId>) -> String {\r\n    if let Some(id) = opt_header {\r\n        format!(\"GET for session {:}\", id.session_id)\r\n    } else {\r\n        format!(\"GET for new session\")\r\n    }\r\n}\r\n```\r\n\r\nIn the current semantics for Option<T> where T: FromRequest, the request will succeed, even with a malformed header, passed in as None. If I were a client of that API, I'd find it highly surprising.\n\n### Suggested Changes\n\nI would suggest that the Option guard semantics were changed to fail if Outcome::Error, mapping Forward to None. In other words, this would be how I'd implement it:\r\n\r\n```rust\r\n#[crate::async_trait]\r\nimpl<'r, T: FromRequest<'r>> FromRequest<'r> for Option<T> {\r\n    type Error = T::Error;\r\n\r\n    async fn from_request(request: &'r Request<'_>) -> Outcome<Self, Self::Error> {\r\n        match T::from_request(request).await {\r\n            Success(val) => Success(Some(val)),\r\n            Forward(_) => Success(None),\r\n            Error((status, error)) => Error((status, error)),\r\n        }\r\n    }\r\n}\r\n```\r\n\r\nThat way, we could keep the parse errors and whatnot as errors (and not silently suppress them). This would compose well with catchers.\n\n### Alternatives Considered\n\nIn the current solution, the only alternative for a handler would be to use the an Outcome guard, like this:\r\n\r\n```rust\r\n#[get(\"/optional2\")]\r\nfn get_data_with_opt_header2(header_outcome: Outcome<SessionId, ParseIntError>) -> (Status, String) {\r\n    match header_outcome {\r\n        Outcome::Success(id) => (Status::Ok, format!(\"GET for session {:}\", id.session_id)),\r\n        Outcome::Error((_, e)) => (Status::BadRequest, format!(\"GET could not get session because: {:}\", e)),\r\n        Outcome::Forward(_) => (Status::Ok, format!(\"GET for new session\")),\r\n    }\r\n}\r\n```\r\nThis adds extra complexity and forces boilerplate error handling code as well as Rocket-specific type use into the handlers. \n\n### Additional Context\n\nIn #2867 I've implemented typed headers (see #1067). This would fit well with these headers, like Option<IfModifiedSince>, etc.\r\n\r\nI have a patch ready.\n\n### System Checks\n\n- [X] I do not believe that this suggestion can or should be implemented outside of Rocket.\n\n- [X] I was unable to find a previous suggestion for this change.","reactions":{"url":"https://api.github.com/repos/rwf2/Rocket/issues/2871/reactions","total_count":0,"+1":0,"-1":0,"laugh":0,"hooray":0,"confused":0,"heart":0,"rocket":0,"eyes":0},"timeline_url":"https://api.github.com/repos/rwf2/Rocket/issues/2871/timeline","performed_via_github_app":null,"state_reason":"not_planned","pinned_comment":null,"score":1.0},{"url":"https://api.github.com/repos/rwf2/Rocket/issues/2877","repository_url":"https://api.github.com/repos/rwf2/Rocket","labels_url":"https://api.github.com/repos/rwf2/Rocket/issues/2877/labels{/name}","comments_url":"https://api.github.com/repos/rwf2/Rocket/issues/2877/comments","events_url":"https://api.github.com/repos/rwf2/Rocket/issues/2877/events","html_url":"https://github.com/rwf2/Rocket/issues/2877","id":2586556345,"node_id":"I_kwDOAzqMt86aK7e5","number":2877,"title":"Tests fail for core http3-preview for crate s2n-quic-h3","user":{"login":"shjohnson-pi","id":3351990,"node_id":"MDQ6VXNlcjMzNTE5OTA=","avatar_url":"https://avatars.githubusercontent.com/u/3351990?v=4","gravatar_id":"","url":"https://api.github.com/users/shjohnson-pi","html_url":"https://github.com/shjohnson-pi","followers_url":"https://api.github.com/users/shjohnson-pi/followers","following_url":"https://api.github.com/users/shjohnson-pi/following{/other_user}","gists_url":"https://api.github.com/users/shjohnson-pi/gists{/gist_id}","starred_url":"https://api.github.com/users/shjohnson-pi/starred{/owner}{/repo}","subscriptions_url":"https://api.github.com/users/shjohnson-pi/subscriptions","organizations_url":"https://api.github.com/users/shjo