cores, click <a href=\"https://www.first.org/cvss/calculator/3.0\">here</a>.\n</p>\n\n<p></p>\n\n###  Suggested Fix\n<p>\n\n<p>Type: Upgrade version</p>\n<p>Origin: <a href=\"https://github.com/honojs/hono/security/advisories/GHSA-hm8q-7f3q-5f36\">https://github.com/honojs/hono/security/advisories/GHSA-hm8q-7f3q-5f36</a></p>\n<p>Release Date: 2026-05-09</p>\n<p>Fix Resolution: hono - 4.12.18</p>\n\n</p>\n\n<p></p>\n\n</details>","reactions":{"url":"https://api.github.com/repos/opensearch-project/opensearch-flux/issues/10/reactions","total_count":0,"+1":0,"-1":0,"laugh":0,"hooray":0,"confused":0,"heart":0,"rocket":0,"eyes":0},"timeline_url":"https://api.github.com/repos/opensearch-project/opensearch-flux/issues/10/timeline","performed_via_github_app":null,"state_reason":"completed","pinned_comment":null,"score":1.0},{"url":"https://api.github.com/repos/Erick52106/spec-injector/issues/223","repository_url":"https://api.github.com/repos/Erick52106/spec-injector","labels_url":"https://api.github.com/repos/Erick52106/spec-injector/issues/223/labels{/name}","comments_url":"https://api.github.com/repos/Erick52106/spec-injector/issues/223/comments","events_url":"https://api.github.com/repos/Erick52106/spec-injector/issues/223/events","html_url":"https://github.com/Erick52106/spec-injector/issues/223","id":4413429938,"node_id":"I_kwDOSRctLM8AAAABBw-Ysg","number":223,"title":"dogfood(plan): run third read-only brownfield evidence gate","user":{"login":"Erick52106","id":253722417,"node_id":"U_kgDODx9_MQ","avatar_url":"https://avatars.githubusercontent.com/u/253722417?v=4","gravatar_id":"","url":"https://api.github.com/users/Erick52106","html_url":"https://github.com/Erick52106","followers_url":"https://api.github.com/users/Erick52106/followers","following_url":"https://api.github.com/users/Erick52106/following{/other_user}","gists_url":"https://api.github.com/users/Erick52106/gists{/gist_id}","starred_url":"https://api.github.com/users/Erick52106/starred{/owner}{/repo}","subsc